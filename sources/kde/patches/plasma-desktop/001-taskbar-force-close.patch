 #include <PlasmaActivities/Consumer>
 #include <PlasmaActivities/Stats/Cleaning>
 #include <PlasmaActivities/Stats/ResultSet>
@@ -518,4 +520,22 @@ qint64 Backend::parentPid(qint64 pid) const
     return -1;
 }
 
+// PowOS: SIGKILL a task's process — used by shift+click on the context
+// menu's Close entry and the shift-revealed "Force Close" entry.
+void Backend::forceKill(qint64 pid) const
+{
+    if (pid <= 1) {
+        return;
+    }
+
+    ::kill(static_cast<pid_t>(pid), SIGKILL);
+}
+
+// PowOS: whether Shift is held right now (same process as the menu, so the
+// modifier state from the triggering input event is current on X11+Wayland).
+bool Backend::shiftPressed() const
+{
+    return QGuiApplication::keyboardModifiers().testFlag(Qt::ShiftModifier);
+}
