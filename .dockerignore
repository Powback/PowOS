# Exclude bazzite-fork (has symlinks that break on Windows)
bazzite-fork/

# Exclude containers build files (has symlinks that break on Windows)
containers/system_files/
containers/build_files/

# Git
.git/

# Never bake credentials into published images
# (Containerfile does `COPY . /var/lib/powos/src/` — anything not excluded
# here ships inside the OS image, which is pushed to GHCR)
secrets/
**/*.pem
**/*.key
**/.env
**/.env.*

# Build artifacts
build/output/
*.raw
*.iso
*.img

# IDE
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/

# Temp
*.tmp
*.log
