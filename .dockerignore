# Exclude bazzite-fork (has symlinks that break on Windows)
bazzite-fork/

# Exclude containers build files (has symlinks that break on Windows)
containers/system_files/
containers/build_files/

# Git
.git/

# Never bake credentials into published images.
# The Containerfile's staging stage bundles a `git archive HEAD` snapshot at
# /usr/lib/powos/src (built as .snapshot/ in CI). `git archive` already
# excludes .git and respects .gitattributes, but anything the workflow
# happens to add to the checkout WOULD ship — belt-and-suspenders:
secrets/
**/*.pem
**/*.key
**/.env
**/.env.*

# Build artifacts
build/output/
*.raw
*.iso
*.img

# IDE
.vscode/
.idea/

# Python
__pycache__/
*.pyc
.venv/

# Temp
*.tmp
*.log
