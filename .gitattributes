# Line-ending policy. This repo runs on Linux but is regularly developed from
# Windows checkouts (see the exec-bit fix history: e770183, 0b3c84f). Pin LF
# for everything Linux executes or parses so core.autocrlf can never convert
# a script into CRLF (which breaks shebangs and systemd unit parsing), and so
# the per-file "LF will be replaced by CRLF" warnings stop.

*.sh        text eol=lf
*.py        text eol=lf
*.service   text eol=lf
*.conf      text eol=lf
*.rules     text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.ini       text eol=lf
*.txt       text eol=lf
*.desktop   text eol=lf
*.env       text eol=lf
Containerfile*  text eol=lf
Dockerfile*     text eol=lf
justfile        text eol=lf
Justfile        text eol=lf
.gitignore      text eol=lf
.gitattributes  text eol=lf
.dockerignore   text eol=lf

# Extensionless executables (dispatched by shebang)
bin/*           text eol=lf
systemd/powos-* text eol=lf
build_files/*   text eol=lf

# Windows-side scripts keep CRLF
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binary assets — never touch
*.wav   binary
*.cer   binary
*.png   binary
*.raw   binary
*.img   binary
*.qcow2 binary
