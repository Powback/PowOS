#!/bin/bash
# homefs-usb-notify - Handle USB connect/disconnect events
# Called by udev rules when HomeFS USB drive is plugged/unplugged

set -euo pipefail

ACTION="${1:-}"
DEVICE="${2:-}"

LOG_TAG="homefs-usb"
STATUS_FILE="/var/run/homefs/usb-status"

log() {
    logger -t "$LOG_TAG" "$*"
    echo "[homefs-usb] $*"
}

case "$ACTION" in
    connect)
        log "USB connected: $DEVICE"
        echo "connected" > "$STATUS_FILE"

        # Signal sync daemon to start syncing
        if systemctl is-active --quiet powos-homefs-sync.service; then
            systemctl kill -s USR1 powos-homefs-sync.service
        fi

        # Desktop notification (if available)
        if command -v notify-send &>/dev/null; then
            sudo -u powos DISPLAY=:0 notify-send "HomeFS" "USB drive connected. Syncing..." -i drive-removable-media
        fi
        ;;

    disconnect)
        log "USB disconnected: $DEVICE"
        echo "disconnected" > "$STATUS_FILE"

        # Desktop notification
        if command -v notify-send &>/dev/null; then
            sudo -u powos DISPLAY=:0 notify-send "HomeFS" "USB drive disconnected. Running from cache." -i drive-removable-media -u critical
        fi
        ;;

    status)
        if [[ -f "$STATUS_FILE" ]]; then
            cat "$STATUS_FILE"
        else
            echo "unknown"
        fi
        ;;

    *)
        echo "Usage: $0 {connect|disconnect|status} [device]"
        exit 1
        ;;
esac
