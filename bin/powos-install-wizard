#!/bin/bash
# powos-install-wizard - guided PowOS disk-install front end.
#
# Thin executable entry point: locates and sources lib/install-wizard.sh, then
# runs cmd_install_wizard. All logic (UI, collectors, config writing, installer
# hand-off) lives in the sourced lib so it can be unit-tested without a disk.
#
# It NEVER partitions anything itself — it wraps `powos install-system`.
#
# Usage:  sudo powos-install-wizard [--dry-run]

set -uo pipefail

# Installed images ship the powos libs in /usr/lib/powos; dev checkouts keep
# them next to bin/. Overridable for tests.
POWOS_LIB="${POWOS_LIB:-/usr/lib/powos}"
if [[ ! -f "$POWOS_LIB/install-wizard.sh" ]]; then
    POWOS_LIB="$(cd "$(dirname "$0")/../lib" && pwd)"
fi

if [[ ! -f "$POWOS_LIB/install-wizard.sh" ]]; then
    echo "powos-install-wizard: cannot find install-wizard.sh (looked in $POWOS_LIB)" >&2
    exit 1
fi

# shellcheck disable=SC1090
source "$POWOS_LIB/install-wizard.sh"

cmd_install_wizard "$@"
