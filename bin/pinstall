#!/usr/bin/env bash
# pinstall - Install packages and automatically record to infrastructure code
#
# Usage: pinstall <package> [package...]
#
# This script:
# 1. Installs packages immediately (runtime)
# 2. Records them to distrobox.ini (config)
# 3. Commits the change to git (persistence)

set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# Configuration
# ─────────────────────────────────────────────────────────────────

POWOS_ROOT="${POWOS_ROOT:-$HOME/powos}"
DISTROBOX_INI="${POWOS_ROOT}/containers/distrobox.ini"
LOG_PREFIX="[pinstall]"

# Container section in distrobox.ini that pinstall/premove manage.
# Only this section's additional_packages= line is ever touched.
POWOS_CONTAINER="${POWOS_CONTAINER:-powos-dev}"

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
    RED=$'\033[0;31m'
    GREEN=$'\033[0;32m'
    YELLOW=$'\033[0;33m'
    BLUE=$'\033[0;34m'
    NC=$'\033[0m' # No Color
else
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

# ─────────────────────────────────────────────────────────────────
# Helper Functions
# ─────────────────────────────────────────────────────────────────

log_info() {
    echo -e "${BLUE}${LOG_PREFIX}${NC} $*"
}

log_success() {
    echo -e "${GREEN}${LOG_PREFIX}${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}${LOG_PREFIX}${NC} $*"
}

log_error() {
    echo -e "${RED}${LOG_PREFIX}${NC} $*" >&2
}

# Detect which package manager is available
detect_package_manager() {
    # Atomic/composefs host (Bazzite/bootc): /usr is read-only and `dnf` is a
    # guard stub — layer via rpm-ostree so packages persist. rpm-ostree is
    # absent inside distrobox containers, so this correctly only fires on host.
    if [[ -f /run/ostree-booted ]] && command -v rpm-ostree &>/dev/null; then
        echo "rpm-ostree"
    elif command -v pacman &>/dev/null; then
        echo "pacman"
    elif command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v apk &>/dev/null; then
        echo "apk"
    elif command -v zypper &>/dev/null; then
        echo "zypper"
    else
        echo "unknown"
    fi
}

# Install packages using the detected package manager
install_packages() {
    local pm="$1"
    shift
    local packages=("$@")

    log_info "Installing with ${pm}: ${packages[*]}"

    case "$pm" in
        rpm-ostree)
            # Layered package on an atomic host; try live-apply, else reboot.
            sudo rpm-ostree install --idempotent --allow-inactive "${packages[@]}"
            if sudo rpm-ostree apply-live --allow-replacement 2>/dev/null; then
                log_success "Applied live — available now, no reboot."
            else
                log_warn "Staged; activate with: systemctl reboot"
            fi
            ;;
        pacman)
            sudo pacman -S --noconfirm --needed "${packages[@]}"
            ;;
        dnf)
            sudo dnf install -y "${packages[@]}"
            ;;
        apt)
            sudo apt-get update -qq
            sudo apt-get install -y "${packages[@]}"
            ;;
        apk)
            sudo apk add "${packages[@]}"
            ;;
        zypper)
            sudo zypper install -y "${packages[@]}"
            ;;
        *)
            log_error "Unknown package manager: $pm"
            return 1
            ;;
    esac
}

# Ensure distrobox.ini exists with proper structure
ensure_distrobox_ini() {
    if [[ ! -f "$DISTROBOX_INI" ]]; then
        log_info "Creating ${DISTROBOX_INI}"
        mkdir -p "$(dirname "$DISTROBOX_INI")"
        cat > "$DISTROBOX_INI" << 'EOF'
# PowOS Distrobox Configuration
# This file is automatically managed by pinstall/premove
# Manual edits will be preserved

[powos-dev]
image=archlinux:latest
additional_packages=
init=false
nvidia=false
pull=true
root=false
replace=true
start_now=false
EOF
    fi
}

# Check whether a package is already listed on the target section's
# additional_packages= line. Whole-name match — no regex, so package names
# with special characters ('g++', 'libstdc++') are handled correctly, and
# 'dev' does not match 'dev-tools'. Other ini sections are ignored.
package_recorded() {
    local pkg="$1"
    local ini_file="$DISTROBOX_INI"
    local in_section=0 line value word

    [[ -f "$ini_file" ]] || return 1

    while IFS= read -r line || [[ -n "$line" ]]; do
        case "$line" in
            "[${POWOS_CONTAINER}]") in_section=1; continue ;;
            "["*"]")                in_section=0; continue ;;
        esac
        if [[ $in_section -eq 1 && "$line" == additional_packages=* ]]; then
            value="${line#additional_packages=}"
            value="${value#\"}"
            value="${value%\"}"
            for word in $value; do
                [[ "$word" == "$pkg" ]] && return 0
            done
        fi
    done < "$ini_file"
    return 1
}

# Rewrite distrobox.ini, adding or removing a package on the target
# section's additional_packages= line ONLY. Pure bash — no sed, no regex on
# package names, other sections are copied through untouched.
# Usage: update_ini_packages {add|remove} <pkg>
update_ini_packages() {
    local action="$1"
    local pkg="$2"
    local ini_file="$DISTROBOX_INI"
    local tmp
    tmp=$(mktemp)

    local in_section=0 section_seen=0 line_handled=0
    local line value new_value word quoted

    while IFS= read -r line || [[ -n "$line" ]]; do
        case "$line" in
            "[${POWOS_CONTAINER}]")
                in_section=1
                section_seen=1
                printf '%s\n' "$line" >> "$tmp"
                continue
                ;;
            "["*"]")
                # Leaving the target section without having seen the line
                if [[ $in_section -eq 1 && $line_handled -eq 0 && "$action" == "add" ]]; then
                    printf 'additional_packages=%s\n' "$pkg" >> "$tmp"
                    line_handled=1
                fi
                in_section=0
                printf '%s\n' "$line" >> "$tmp"
                continue
                ;;
        esac

        if [[ $in_section -eq 1 && $line_handled -eq 0 && "$line" == additional_packages=* ]]; then
            line_handled=1
            value="${line#additional_packages=}"
            quoted=0
            if [[ "$value" == \"*\" ]]; then
                quoted=1
                value="${value#\"}"
                value="${value%\"}"
            fi
            new_value=""
            for word in $value; do
                if [[ "$action" == "remove" && "$word" == "$pkg" ]]; then
                    continue
                fi
                new_value+="${new_value:+ }${word}"
            done
            if [[ "$action" == "add" ]]; then
                new_value+="${new_value:+ }${pkg}"
            fi
            if [[ $quoted -eq 1 ]]; then
                printf 'additional_packages="%s"\n' "$new_value" >> "$tmp"
            else
                printf 'additional_packages=%s\n' "$new_value" >> "$tmp"
            fi
        else
            printf '%s\n' "$line" >> "$tmp"
        fi
    done < "$ini_file"

    # File ended while still inside the target section
    if [[ $in_section -eq 1 && $line_handled -eq 0 && "$action" == "add" ]]; then
        printf 'additional_packages=%s\n' "$pkg" >> "$tmp"
        line_handled=1
    fi

    # Section missing entirely — create it (add only)
    if [[ $section_seen -eq 0 && "$action" == "add" ]]; then
        {
            echo ""
            echo "[${POWOS_CONTAINER}]"
            echo "additional_packages=${pkg}"
        } >> "$tmp"
    fi

    mv "$tmp" "$ini_file"
}

# Add package to distrobox.ini
record_package() {
    local pkg="$1"

    # Ensure file exists
    ensure_distrobox_ini

    # Check if package already recorded (in the target section)
    if package_recorded "$pkg"; then
        log_warn "Package '$pkg' already in config"
        return 0
    fi

    update_ini_packages add "$pkg"

    log_info "Recorded '$pkg' to config"
}

# Commit changes to git
commit_changes() {
    local packages=("$@")
    local msg="install: ${packages[*]}"

    cd "$POWOS_ROOT"

    # Check if we're in a git repo
    if ! git rev-parse --git-dir &>/dev/null; then
        log_warn "Not a git repository, skipping commit"
        return 0
    fi

    # Check if there are changes
    if ! git diff --quiet "$DISTROBOX_INI" 2>/dev/null && \
       ! git diff --cached --quiet "$DISTROBOX_INI" 2>/dev/null; then
        git add "$DISTROBOX_INI"
        git commit -m "$msg" || log_warn "Nothing to commit"
        log_success "Committed: $msg"
    else
        log_warn "No changes to commit"
    fi
}

# ─────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────

main() {
    local packages=("$@")

    # Validate arguments
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo "Usage: pinstall <package> [package...]"
        echo ""
        echo "Install packages and record to infrastructure code."
        echo ""
        echo "Examples:"
        echo "  pinstall ripgrep"
        echo "  pinstall node python go"
        echo ""
        echo "Environment variables:"
        echo "  POWOS_ROOT       Root directory (default: \$HOME/powos)"
        echo "  POWOS_SKIP_GIT   Skip git commit if set to 1"
        exit 1
    fi

    log_info "Installing: ${packages[*]}"

    # Step 1: Detect package manager
    local pm
    pm=$(detect_package_manager)

    if [[ "$pm" == "unknown" ]]; then
        log_error "No supported package manager found"
        exit 1
    fi

    # Step 2: Install packages (runtime)
    if ! install_packages "$pm" "${packages[@]}"; then
        log_error "Installation failed"
        exit 1
    fi

    # Step 3: Record to config
    ensure_distrobox_ini
    for pkg in "${packages[@]}"; do
        record_package "$pkg"
    done

    # Step 4: Git commit (persistence)
    if [[ "${POWOS_SKIP_GIT:-0}" != "1" ]]; then
        commit_changes "${packages[@]}"
    fi

    log_success "Installed and recorded: ${packages[*]}"
}

main "$@"
