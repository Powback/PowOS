#!/bin/bash
# powos - PowOS CLI
#
# Main command interface for PowOS system management.

set -e

VERSION="0.3.0"
LAYER_SYNC="/usr/lib/powos/ramfs/layer-sync.py"
STATE_DIR="/run/powos"

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

usage() {
    cat << EOF
PowOS - Portable Gaming Workstation

Usage: powos <command> [options]

Commands:
  status              Show full system status
  sync                Force sync RAM changes to USB
  safe                Check if safe to unplug USB

  layers              Show active layers
  layers status       Detailed layer status
  layers sync         Sync RAM to custom layer now
  layers clear custom Clear custom layer entirely
  layers clear updates Clear updates layer entirely

  rollback            Show rollback options
  rollback custom     Boot without custom layer (next boot)
  rollback updates    Boot without updates layer (next boot)
  rollback all        Boot with base only (next boot)
  rollback reset      Clear rollback flags

  update              Check for available updates
  update os           Apply OS updates (to updates layer)
  update packages     Apply package updates (to custom layer)
  update apply        Apply all updates

  hardware            Show detected hardware
  profile             Show active hardware profile

  containers          List containers and images
  containers create   Create a new distrobox container
  containers enter    Enter a distrobox container
  containers assemble Create all predefined containers
  containers prune    Clean up unused resources

  install <pkg>       Install package to host (custom layer)
  install -c NAME <pkg>  Install package to container
  install -c NAME -e <pkg>  Install GUI app to container + export to host

  build [path] [tag]  Build container from Dockerfile/Containerfile

  dev                 List all dev projects
  dev new <name>      Create new project from scratch
  dev fork <upstream> Fork existing app (e.g., kde:dolphin)
  dev build <name>    Build project
  dev enable <name>   Install to system (as overlay)
  dev disable <name>  Remove from system
  dev update <name>   Pull upstream changes (forks only)

  version             Show version

Examples:
  powos status                        # Quick status check
  powos sync                          # Force sync now
  powos layers                        # See active layers
  powos rollback custom               # Skip custom layer on next boot

  powos install neovim htop           # Install to host
  powos install -c dev nodejs npm     # Install to 'dev' container
  powos install -c arch -e firefox    # Install Firefox in Arch, export to host menu

  # Create a new app:
  powos dev new myapp
  cd /var/lib/powos/projects/myapp/src
  # write code
  powos dev build myapp
  powos dev enable myapp

  # Customize KDE apps:
  powos dev fork kde:dolphin
  cd /var/lib/powos/projects/dolphin/src
  # edit files
  powos dev build dolphin
  powos dev enable dolphin

  powos containers create dev         # Create Fedora dev container
  powos containers enter dev          # Enter the container
  powos build . myapp:latest          # Build from Dockerfile

EOF
}

# ═══════════════════════════════════════════════════════════════════
# Utility Functions
# ═══════════════════════════════════════════════════════════════════

# Get USB status
get_usb_status() {
    if [[ -f "$STATE_DIR/usb-state" ]]; then
        source "$STATE_DIR/usb-state"
        echo "$USB_STATUS"
    else
        echo "unknown"
    fi
}

# Check if running in full ramboot mode
is_ramboot() {
    [[ -f "$STATE_DIR/ramboot-state" ]]
}

# Get ramboot info
get_ramboot_info() {
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        echo "$POWOS_RAM_SIZE"
    else
        echo "N/A"
    fi
}

# Get active layers
get_active_layers() {
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        echo "$POWOS_LAYERS_ACTIVE"
    else
        echo "none"
    fi
}

# Check if CacheFS is running
is_cachefs_active() {
    mountpoint -q /home/powos 2>/dev/null && \
        [[ -f "$STATE_DIR/cachefs-status.json" ]]
}

# Check if safe to unplug
is_safe_to_unplug() {
    local pending=0
    for status_file in "$STATE_DIR/layer-sync-status.json" "$STATE_DIR/cachefs-status.json"; do
        if [[ -f "$status_file" ]]; then
            local p
            p=$(python3 -c "import json; print(json.load(open('$status_file')).get('pending_changes', 0))" 2>/dev/null || echo "0")
            pending=$((pending + p))
        fi
    done
    [[ "$pending" == "0" ]]
}

# ═══════════════════════════════════════════════════════════════════
# Status Command
# ═══════════════════════════════════════════════════════════════════

cmd_status() {
    echo -e "${BOLD}${CYAN}PowOS Status${NC}"
    echo "════════════════════════════════════════"
    echo ""

    # === Layers ===
    echo -e "${CYAN}Active Layers${NC}"
    local layers
    layers=$(get_active_layers)
    if [[ "$layers" != "none" ]]; then
        echo -e "  Stack:      ${GREEN}$layers${NC}"
        # Parse and show each layer
        IFS=',' read -ra LAYER_ARR <<< "$layers"
        for layer in "${LAYER_ARR[@]}"; do
            case "$layer" in
                custom)
                    echo -e "              ├─ ${GREEN}●${NC} custom (your packages & configs)"
                    ;;
                updates)
                    echo -e "              ├─ ${GREEN}●${NC} updates (OS updates)"
                    ;;
                base)
                    echo -e "              └─ ${GREEN}●${NC} base (Bazzite)"
                    ;;
            esac
        done
    else
        echo -e "  Stack:      ${YELLOW}Standard boot (no layers)${NC}"
    fi

    # Check for skipped layers
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        if [[ "$POWOS_SKIP_CUSTOM" == "1" ]]; then
            echo -e "  ${YELLOW}⚠ Custom layer SKIPPED (rollback active)${NC}"
        fi
        if [[ "$POWOS_SKIP_UPDATES" == "1" ]]; then
            echo -e "  ${YELLOW}⚠ Updates layer SKIPPED (rollback active)${NC}"
        fi
    fi
    echo ""

    # === RAM Status ===
    echo -e "${CYAN}RAM Overlay${NC}"
    if is_ramboot; then
        echo -e "  Mode:       ${GREEN}● Running from RAM${NC}"
        local ram_size
        ram_size=$(get_ramboot_info)
        echo "  Allocated:  $ram_size"
        if [[ -d /run/powos-overlay/upper ]]; then
            local upper_used
            upper_used=$(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo "0")
            echo "  Used:       $upper_used (changes since boot)"
        fi
    else
        echo -e "  Mode:       ${YELLOW}○ Standard (no RAM overlay)${NC}"
    fi
    echo ""

    # === User Data ===
    echo -e "${CYAN}User Data (/home)${NC}"
    if is_cachefs_active; then
        echo -e "  Mode:       ${GREEN}● CacheFS (lazy-load)${NC}"
        if [[ -f "$STATE_DIR/cachefs-status.json" ]]; then
            python3 -c "
import json
s = json.load(open('$STATE_DIR/cachefs-status.json'))
print(f\"  USB:        {'Connected' if s.get('usb_connected') else 'Disconnected'}\")
print(f\"  Cached:     {s.get('cached_files', 0)} files\")
" 2>/dev/null || true
        fi
    elif mountpoint -q /home/powos 2>/dev/null; then
        echo -e "  Mode:       ${CYAN}○ Direct USB${NC}"
    else
        echo -e "  Mode:       ${YELLOW}○ tmpfs (temporary)${NC}"
    fi
    echo ""

    # === USB Status ===
    echo -e "${CYAN}USB Drive${NC}"
    local usb_status
    usb_status=$(get_usb_status)
    case "$usb_status" in
        connected)
            echo -e "  Status:     ${GREEN}● Connected${NC}"
            ;;
        disconnected)
            echo -e "  Status:     ${YELLOW}○ Disconnected${NC}"
            ;;
        *)
            echo -e "  Status:     ${RED}? Unknown${NC}"
            ;;
    esac

    # Last sync
    if [[ -f "$STATE_DIR/layer-sync-status.json" ]]; then
        local last_sync
        last_sync=$(python3 -c "
import json, time
s = json.load(open('$STATE_DIR/layer-sync-status.json'))
t = s.get('last_sync', 0)
if t > 0:
    delta = int(time.time() - t)
    if delta < 60: print(f'{delta}s ago')
    elif delta < 3600: print(f'{delta // 60}m ago')
    else: print(f'{delta // 3600}h ago')
else: print('Never')
" 2>/dev/null || echo "Unknown")
        echo "  Last Sync:  $last_sync"
    fi
    echo ""

    # === Protection Summary ===
    echo -e "${CYAN}Unplug Safety${NC}"
    if is_ramboot && is_cachefs_active; then
        echo -e "  ${GREEN}✓ FULLY PROTECTED${NC}"
        echo "    OS in RAM, user data cached"
        echo "    USB can be unplugged anytime!"
    elif is_ramboot; then
        echo -e "  ${GREEN}✓ OS Protected${NC}"
        echo "    OS in RAM, user data may need USB"
    elif is_cachefs_active; then
        echo -e "  ${CYAN}◐ Partial${NC}"
        echo "    User data cached, OS needs USB"
    else
        echo -e "  ${RED}✗ Not Protected${NC}"
        echo "    USB required for operation"
    fi
    echo ""
}

# ═══════════════════════════════════════════════════════════════════
# Layers Command
# ═══════════════════════════════════════════════════════════════════

cmd_layers() {
    local subcmd="${1:-status}"

    case "$subcmd" in
        status)
            echo -e "${BOLD}${CYAN}Layer Stack${NC}"
            echo "════════════════════════════════════════"
            echo ""
            echo "  Writes → [RAM Upper] → sync → [Custom Layer] → USB"
            echo ""
            echo "  Lower layers (read-only at runtime):"

            local layers
            layers=$(get_active_layers)

            # Custom layer
            if [[ "$layers" == *"custom"* ]]; then
                echo -e "    ${GREEN}●${NC} custom    - Your packages, configs, customizations"
                if [[ -d /run/powos/usb-layers/layers/custom ]]; then
                    local size
                    size=$(du -sh /run/powos/usb-layers/layers/custom 2>/dev/null | cut -f1 || echo "empty")
                    echo "                  Size: $size"
                fi
            else
                echo -e "    ${YELLOW}○${NC} custom    - (empty or skipped)"
            fi

            # Updates layer
            if [[ "$layers" == *"updates"* ]]; then
                echo -e "    ${GREEN}●${NC} updates   - OS updates"
                if [[ -d /run/powos/usb-layers/layers/updates ]]; then
                    local size
                    size=$(du -sh /run/powos/usb-layers/layers/updates 2>/dev/null | cut -f1 || echo "empty")
                    echo "                  Size: $size"
                fi
            else
                echo -e "    ${YELLOW}○${NC} updates   - (empty or skipped)"
            fi

            # Base layer
            echo -e "    ${GREEN}●${NC} base      - Bazzite OS image"
            echo ""

            # RAM upper stats
            echo "  RAM Upper (writes since boot):"
            if [[ -d /run/powos-overlay/upper ]]; then
                local files count size
                count=$(find /run/powos-overlay/upper -type f 2>/dev/null | wc -l)
                size=$(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo "0")
                echo "    Files changed: $count"
                echo "    Size: $size"
            else
                echo "    (not available)"
            fi
            echo ""
            ;;

        sync)
            echo "Syncing RAM changes to custom layer..."
            if [[ -x "$LAYER_SYNC" ]]; then
                python3 "$LAYER_SYNC" --sync-now
            else
                echo "Layer sync not available"
                exit 1
            fi
            ;;

        clear)
            local layer="${2:-}"
            case "$layer" in
                custom)
                    echo -e "${YELLOW}Clearing custom layer...${NC}"
                    if [[ "$(get_usb_status)" != "connected" ]]; then
                        echo -e "${RED}Error: USB not connected${NC}"
                        exit 1
                    fi
                    local custom_path="/run/powos/usb-layers/layers/custom"
                    if [[ -d "$custom_path" ]]; then
                        rm -rf "${custom_path:?}"/*
                        echo -e "${GREEN}✓ Custom layer cleared${NC}"
                        echo "  Your customizations will be gone on next boot"
                        echo "  Current session still has changes in RAM"
                    else
                        echo "Custom layer path not found"
                        exit 1
                    fi
                    ;;
                updates)
                    echo -e "${YELLOW}Clearing updates layer...${NC}"
                    if [[ "$(get_usb_status)" != "connected" ]]; then
                        echo -e "${RED}Error: USB not connected${NC}"
                        exit 1
                    fi
                    local updates_path="/run/powos/usb-layers/layers/updates"
                    if [[ -d "$updates_path" ]]; then
                        rm -rf "${updates_path:?}"/*
                        echo -e "${GREEN}✓ Updates layer cleared${NC}"
                        echo "  OS updates will be gone on next boot"
                    else
                        echo "Updates layer path not found"
                        exit 1
                    fi
                    ;;
                *)
                    echo "Usage: powos layers clear {custom|updates}"
                    echo ""
                    echo "  custom   - Clear your packages, configs, customizations"
                    echo "  updates  - Clear OS updates"
                    ;;
            esac
            ;;

        *)
            echo "Usage: powos layers {status|sync|clear}"
            echo ""
            echo "  status              - Show layer stack"
            echo "  sync                - Force sync RAM to custom layer"
            echo "  clear custom        - Clear custom layer"
            echo "  clear updates       - Clear updates layer"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Rollback Command
# ═══════════════════════════════════════════════════════════════════

cmd_rollback() {
    local target="${1:-}"
    local GRUB_CFG="/etc/default/grub"
    local KARGS_FILE="/run/powos/rollback-kargs"

    case "$target" in
        "")
            echo -e "${BOLD}${CYAN}Rollback Options${NC}"
            echo "════════════════════════════════════════"
            echo ""
            echo "Rollback allows you to boot without specific layers."
            echo "Useful when an update or customization breaks something."
            echo ""
            echo "Commands:"
            echo "  powos rollback custom   - Skip custom layer (next boot)"
            echo "  powos rollback updates  - Skip updates layer (next boot)"
            echo "  powos rollback all      - Boot base only (next boot)"
            echo "  powos rollback reset    - Clear rollback flags"
            echo ""

            # Show current rollback state
            if [[ -f "$KARGS_FILE" ]]; then
                echo -e "${YELLOW}Active rollback flags:${NC}"
                cat "$KARGS_FILE"
                echo ""
            fi

            # Show what layers are currently skipped
            if [[ -f "$STATE_DIR/ramboot-state" ]]; then
                source "$STATE_DIR/ramboot-state"
                if [[ "$POWOS_SKIP_CUSTOM" == "1" ]] || [[ "$POWOS_SKIP_UPDATES" == "1" ]]; then
                    echo -e "${YELLOW}Currently running with rollback:${NC}"
                    [[ "$POWOS_SKIP_CUSTOM" == "1" ]] && echo "  - Custom layer skipped"
                    [[ "$POWOS_SKIP_UPDATES" == "1" ]] && echo "  - Updates layer skipped"
                fi
            fi
            ;;

        custom)
            echo "Setting rollback: skip custom layer on next boot"
            mkdir -p "$(dirname "$KARGS_FILE")"
            echo "rd.powos.skip.custom=1" >> "$KARGS_FILE"

            # Try to update kernel cmdline for next boot
            if command -v grubby &>/dev/null; then
                grubby --update-kernel=ALL --args="rd.powos.skip.custom=1" 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Custom layer will be skipped on next boot${NC}"
            echo "  Your customizations won't load - only base + updates"
            echo "  Run 'powos rollback reset' to undo"
            ;;

        updates)
            echo "Setting rollback: skip updates layer on next boot"
            mkdir -p "$(dirname "$KARGS_FILE")"
            echo "rd.powos.skip.updates=1" >> "$KARGS_FILE"

            if command -v grubby &>/dev/null; then
                grubby --update-kernel=ALL --args="rd.powos.skip.updates=1" 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Updates layer will be skipped on next boot${NC}"
            echo "  System updates won't load - only base + custom"
            echo "  Run 'powos rollback reset' to undo"
            ;;

        all)
            echo "Setting rollback: boot with base only"
            mkdir -p "$(dirname "$KARGS_FILE")"
            echo "rd.powos.skip.custom=1" > "$KARGS_FILE"
            echo "rd.powos.skip.updates=1" >> "$KARGS_FILE"

            if command -v grubby &>/dev/null; then
                grubby --update-kernel=ALL --args="rd.powos.skip.custom=1 rd.powos.skip.updates=1" 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Will boot with base layer only${NC}"
            echo "  No customizations or updates will load"
            echo "  Run 'powos rollback reset' to undo"
            ;;

        reset)
            echo "Clearing rollback flags..."
            rm -f "$KARGS_FILE"

            if command -v grubby &>/dev/null; then
                grubby --update-kernel=ALL --remove-args="rd.powos.skip.custom rd.powos.skip.updates" 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Rollback flags cleared${NC}"
            echo "  All layers will load on next boot"
            ;;

        *)
            echo "Unknown rollback target: $target"
            echo "Valid options: custom, updates, all, reset"
            exit 1
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Update Command
# ═══════════════════════════════════════════════════════════════════

cmd_update() {
    local action="${1:-check}"
    local UPDATES_LAYER="/run/powos/usb-layers/layers/updates"

    case "$action" in
        check)
            echo -e "${BOLD}${CYAN}Checking for Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Check bootc for base OS updates
            echo "Base OS (via bootc):"
            if command -v bootc &>/dev/null; then
                if bootc upgrade --check 2>/dev/null; then
                    echo "  Run 'powos update os' to apply"
                else
                    echo "  System is up to date (or offline)"
                fi
            else
                echo "  bootc not available"
            fi
            echo ""

            # Check for package updates
            echo "Packages (via dnf):"
            if command -v dnf &>/dev/null; then
                local updates
                updates=$(dnf check-update --quiet 2>/dev/null | wc -l || echo "0")
                if [[ "$updates" -gt 0 ]]; then
                    echo "  $updates package updates available"
                    echo "  Run 'powos update packages' to install"
                else
                    echo "  System is up to date"
                fi
            fi
            echo ""
            echo "Commands:"
            echo "  powos update os        - Apply OS updates (goes to updates layer)"
            echo "  powos update packages  - Apply package updates (goes to custom layer)"
            echo "  powos update apply     - Apply all updates"
            ;;

        os)
            echo -e "${BOLD}${CYAN}Applying OS Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Ensure USB is connected
            if [[ "$(get_usb_status)" != "connected" ]]; then
                echo -e "${RED}Error: USB not connected${NC}"
                echo "Updates need USB connected to persist to updates layer"
                exit 1
            fi

            # Create updates layer directory
            mkdir -p "$UPDATES_LAYER"

            if command -v bootc &>/dev/null; then
                echo "Fetching OS update via bootc..."
                echo "This updates the base OS image without affecting your customizations."
                echo ""

                # bootc upgrade will stage the update
                # On atomic systems, this prepares the update for next boot
                if bootc upgrade 2>&1; then
                    echo ""
                    echo -e "${GREEN}✓ OS update staged${NC}"
                    echo "  Update will be applied on next boot"
                    echo "  Your customizations remain in the custom layer"
                    echo ""
                    echo "  If the update causes issues, run:"
                    echo "    powos rollback updates"
                else
                    echo -e "${RED}OS update failed${NC}"
                    exit 1
                fi
            else
                echo -e "${YELLOW}bootc not available${NC}"
                echo "Falling back to dnf for system updates..."
                echo "These updates will go to the updates layer."
                echo ""

                # For non-bootc systems, use dnf but target updates layer
                # This requires mounting updates layer as writable
                if [[ -d "$UPDATES_LAYER" ]]; then
                    # Use dnf with installroot to put updates in the layer
                    echo "Installing system updates to updates layer..."
                    dnf upgrade -y --installroot="$UPDATES_LAYER" --releasever=/ 2>/dev/null || \
                        dnf upgrade -y  # Fallback to normal upgrade
                fi

                echo ""
                echo -e "${GREEN}✓ System updates applied${NC}"
            fi
            ;;

        packages)
            echo -e "${BOLD}${CYAN}Applying Package Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Ensure USB is connected for persistence
            if [[ "$(get_usb_status)" != "connected" ]]; then
                echo -e "${RED}Error: USB not connected${NC}"
                echo "Updates need USB connected to persist"
                exit 1
            fi

            # Apply package updates (goes to RAM, syncs to custom layer)
            if command -v dnf &>/dev/null; then
                echo "Installing package updates..."
                echo "These go to your custom layer (separate from OS updates)."
                echo ""
                dnf upgrade -y

                # Sync to custom layer
                echo ""
                echo "Syncing to custom layer..."
                if [[ -x "$LAYER_SYNC" ]]; then
                    python3 "$LAYER_SYNC" --sync-now
                fi
            fi

            echo ""
            echo -e "${GREEN}✓ Package updates applied${NC}"
            echo "  Changes synced to custom layer"
            echo "  Will persist across reboots"
            ;;

        apply)
            echo -e "${BOLD}${CYAN}Applying All Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Ensure USB is connected for persistence
            if [[ "$(get_usb_status)" != "connected" ]]; then
                echo -e "${RED}Error: USB not connected${NC}"
                echo "Updates need USB connected to persist"
                exit 1
            fi

            # Apply OS updates first
            echo "=== OS Updates ==="
            if command -v bootc &>/dev/null; then
                bootc upgrade 2>&1 || echo "No OS updates or bootc failed"
            fi
            echo ""

            # Then package updates
            echo "=== Package Updates ==="
            if command -v dnf &>/dev/null; then
                dnf upgrade -y
            fi

            # Sync to custom layer
            echo ""
            echo "Syncing to custom layer..."
            if [[ -x "$LAYER_SYNC" ]]; then
                python3 "$LAYER_SYNC" --sync-now
            fi

            echo ""
            echo -e "${GREEN}✓ All updates applied${NC}"
            echo "  OS updates staged for next boot (updates layer)"
            echo "  Package updates synced to custom layer"
            ;;

        *)
            echo "Usage: powos update {check|os|packages|apply}"
            echo ""
            echo "  check     - Check for available updates"
            echo "  os        - Apply OS updates (goes to updates layer)"
            echo "  packages  - Apply package updates (goes to custom layer)"
            echo "  apply     - Apply all updates"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Sync Command
# ═══════════════════════════════════════════════════════════════════

cmd_sync() {
    echo "Syncing all changes to USB..."

    # Sync layer changes
    if [[ -x "$LAYER_SYNC" ]]; then
        python3 "$LAYER_SYNC" --sync-now
    fi

    # Sync CacheFS if active
    if [[ -f "$STATE_DIR/cachefs-status.json" ]]; then
        python3 /usr/lib/powos/cachefs/cachefs-sync.py --sync-now 2>/dev/null || true
    fi

    echo -e "${GREEN}✓ Sync complete${NC}"
}

# ═══════════════════════════════════════════════════════════════════
# Other Commands
# ═══════════════════════════════════════════════════════════════════

cmd_safe() {
    if is_safe_to_unplug; then
        echo -e "${GREEN}✓ Safe to unplug USB${NC}"
        exit 0
    else
        echo -e "${RED}✗ Not safe - sync in progress${NC}"
        echo "  Run 'powos sync' first"
        exit 1
    fi
}

cmd_hardware() {
    if [[ -f "$STATE_DIR/hardware" ]]; then
        cat "$STATE_DIR/hardware"
    else
        echo "Hardware not detected yet"
    fi
}

cmd_version() {
    echo "PowOS version $VERSION"
    if is_ramboot; then
        echo "Layers: $(get_active_layers)"
    fi
}

# ═══════════════════════════════════════════════════════════════════
# Install Command - Unified package installation
# ═══════════════════════════════════════════════════════════════════

cmd_install() {
    local target=""
    local packages=()
    local export_gui=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --container|-c)
                target="$2"
                shift 2
                ;;
            --export|-e)
                export_gui=true
                shift
                ;;
            --help|-h)
                echo "Usage: powos install [options] <packages...>"
                echo ""
                echo "Install packages to the host OS or a container."
                echo ""
                echo "Options:"
                echo "  --container, -c NAME   Install to a distrobox container"
                echo "  --export, -e           Export GUI apps to host menu (with -c)"
                echo ""
                echo "Examples:"
                echo "  powos install neovim htop        # Install to host (custom layer)"
                echo "  powos install -c dev nodejs      # Install nodejs in 'dev' container"
                echo "  powos install -c dev -e code     # Install VSCode in container, export to host"
                echo "  powos install -c arch -e firefox # Install Firefox in Arch, use on host"
                return 0
                ;;
            *)
                packages+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#packages[@]} -eq 0 ]]; then
        echo "Error: No packages specified"
        echo "Run 'powos install --help' for usage"
        return 1
    fi

    if [[ -n "$target" ]]; then
        # Install to container
        echo -e "${CYAN}Installing to container '$target':${NC} ${packages[*]}"

        # Check if container exists
        if ! distrobox list 2>/dev/null | grep -q "^$target"; then
            echo -e "${YELLOW}Container '$target' doesn't exist. Create it first:${NC}"
            echo "  powos containers create $target"
            return 1
        fi

        # Run install inside container
        distrobox enter "$target" -- bash -c "
            if command -v apt &>/dev/null; then
                sudo apt update && sudo apt install -y ${packages[*]}
            elif command -v dnf &>/dev/null; then
                sudo dnf install -y ${packages[*]}
            elif command -v pacman &>/dev/null; then
                sudo pacman -Syu --noconfirm ${packages[*]}
            elif command -v apk &>/dev/null; then
                sudo apk add ${packages[*]}
            else
                echo 'Unknown package manager'
                exit 1
            fi
        "

        if [[ "$export_gui" == "true" ]]; then
            echo ""
            echo -e "${CYAN}Exporting GUI apps to host menu...${NC}"
            for pkg in "${packages[@]}"; do
                # Try to export the app (may fail if not a GUI app, that's ok)
                distrobox-export --app "$pkg" 2>/dev/null && \
                    echo -e "  ${GREEN}✓${NC} Exported: $pkg" || \
                    echo -e "  ${YELLOW}○${NC} Not a GUI app: $pkg"
            done
        fi

        echo ""
        echo -e "${GREEN}✓ Installed to container '$target'${NC}"
        if [[ "$export_gui" == "true" ]]; then
            echo "  GUI apps are now in your application menu!"
        else
            echo "  Enter with: powos containers enter $target"
        fi
    else
        # Install to host (use pinstall logic)
        echo -e "${CYAN}Installing to host:${NC} ${packages[*]}"

        # Detect package manager
        if command -v dnf &>/dev/null; then
            sudo dnf install -y "${packages[@]}"
        elif command -v apt &>/dev/null; then
            sudo apt update && sudo apt install -y "${packages[@]}"
        elif command -v pacman &>/dev/null; then
            sudo pacman -Syu --noconfirm "${packages[@]}"
        else
            echo "No supported package manager found"
            return 1
        fi

        # Sync to custom layer if ramboot active
        if is_ramboot && [[ -x "$LAYER_SYNC" ]]; then
            echo "Syncing to custom layer..."
            python3 "$LAYER_SYNC" --sync-now 2>/dev/null || true
        fi

        echo ""
        echo -e "${GREEN}✓ Installed to host${NC}"
        echo "  Changes will persist in custom layer"
    fi
}

# ═══════════════════════════════════════════════════════════════════
# Build Command - Build containers from Dockerfile/Containerfile
# ═══════════════════════════════════════════════════════════════════

cmd_build() {
    local context="${1:-.}"
    local tag="${2:-}"
    local dockerfile=""

    # Find Dockerfile or Containerfile
    if [[ -f "$context/Containerfile" ]]; then
        dockerfile="$context/Containerfile"
    elif [[ -f "$context/Dockerfile" ]]; then
        dockerfile="$context/Dockerfile"
    elif [[ -f "$context" ]]; then
        dockerfile="$context"
        context=$(dirname "$dockerfile")
    else
        echo "Usage: powos build [context] [tag]"
        echo ""
        echo "Build a container image from Dockerfile or Containerfile."
        echo ""
        echo "Examples:"
        echo "  powos build                        # Build from ./Containerfile or ./Dockerfile"
        echo "  powos build . myapp:latest         # Build with tag"
        echo "  powos build ./path/to/project      # Build from specific directory"
        echo ""
        echo "Note: Podman reads Dockerfiles natively - no conversion needed!"
        return 1
    fi

    echo -e "${CYAN}Building from:${NC} $dockerfile"
    [[ -n "$tag" ]] && echo -e "${CYAN}Tag:${NC} $tag"
    echo ""

    local cmd="podman build"
    [[ -n "$tag" ]] && cmd="$cmd -t $tag"
    cmd="$cmd -f $dockerfile $context"

    echo -e "${YELLOW}Running:${NC} $cmd"
    echo ""

    eval "$cmd"
    local result=$?

    if [[ $result -eq 0 ]]; then
        echo ""
        echo -e "${GREEN}✓ Build successful${NC}"
        [[ -n "$tag" ]] && echo "  Run with: podman run $tag"
    else
        echo ""
        echo -e "${RED}✗ Build failed${NC}"
    fi

    return $result
}

# ═══════════════════════════════════════════════════════════════════
# Source Commands - Build custom versions of apps
# ═══════════════════════════════════════════════════════════════════

SOURCES_DIR="${POWOS_ROOT:-/var/lib/powos}/sources"
PROJECTS_DIR="${POWOS_ROOT:-/var/lib/powos}/projects"
EXTENSIONS_DIR="${POWOS_ROOT:-/var/lib/powos}/extensions"

# Source the unified dev system
if [[ -f /usr/lib/powos/dev-commands.sh ]]; then
    source /usr/lib/powos/dev-commands.sh
elif [[ -f "$(dirname "$0")/../lib/dev-commands.sh" ]]; then
    source "$(dirname "$0")/../lib/dev-commands.sh"
fi

# Legacy source command (kept for backward compatibility)
cmd_source() {
    local action="${1:-list}"

    case "$action" in
        list|ls)
            echo -e "${BOLD}${CYAN}Available Sources${NC}"
            echo "════════════════════════════════════════"
            echo ""

            if [[ ! -d "$SOURCES_DIR" ]]; then
                echo "No sources directory found"
                return 1
            fi

            for src in "$SOURCES_DIR"/*/; do
                local name=$(basename "$src")
                [[ "$name" == "*" ]] && continue

                local conf="$src/source.conf"
                local desc="Custom overlay"
                local upstream=""

                if [[ -f "$conf" ]]; then
                    source "$conf" 2>/dev/null || true
                    desc="${DESCRIPTION:-$desc}"
                    upstream="${UPSTREAM_URL:-}"
                fi

                # Check if built
                local status="${YELLOW}○${NC}"
                if [[ -d "$EXTENSIONS_DIR/$name" ]]; then
                    status="${GREEN}●${NC}"
                fi

                echo -e "  $status $name"
                echo "      $desc"
                [[ -n "$upstream" ]] && echo "      Source: $upstream"
            done
            echo ""
            echo "Legend: ${GREEN}●${NC} built  ${YELLOW}○${NC} not built"
            ;;

        get)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source get <name>"
                echo "       powos source get kde           # Fetch all KDE apps"
                echo "       powos source get kde:dolphin   # Fetch just Dolphin"
                echo ""
                echo "Fetch upstream source code for an app."
                echo "Run 'powos source list' to see available sources."
                return 1
            fi

            # Handle kde:app syntax
            local base_name="${name%%:*}"
            local app_name="${name#*:}"
            [[ "$base_name" == "$app_name" ]] && app_name=""

            local src_dir="$SOURCES_DIR/$base_name"
            local conf="$src_dir/source.conf"

            if [[ ! -f "$conf" ]]; then
                echo -e "${RED}No source.conf for '$base_name'${NC}"
                echo "Create one at: $conf"
                return 1
            fi

            # Special handling for kde - use fetch.sh
            if [[ "$base_name" == "kde" ]] && [[ -x "$src_dir/fetch.sh" ]]; then
                echo -e "${CYAN}Fetching KDE sources...${NC}"
                if [[ -n "$app_name" ]]; then
                    bash "$src_dir/fetch.sh" "$app_name"
                else
                    bash "$src_dir/fetch.sh"
                fi
                return $?
            fi

            source "$conf"

            if [[ -z "${UPSTREAM_URL:-}" ]]; then
                echo -e "${RED}No UPSTREAM_URL defined in source.conf${NC}"
                return 1
            fi

            local src_code_dir="$src_dir/upstream"
            echo -e "${CYAN}Fetching source for $name...${NC}"
            echo "  URL: $UPSTREAM_URL"
            echo "  Dir: $src_code_dir"
            echo ""

            mkdir -p "$src_code_dir"

            if [[ "$UPSTREAM_URL" == *.git ]] || [[ "$UPSTREAM_URL" == *github.com* ]] || [[ "$UPSTREAM_URL" == *gitlab.com* ]]; then
                # Git repo
                if [[ -d "$src_code_dir/.git" ]]; then
                    echo "Updating existing clone..."
                    cd "$src_code_dir" && git pull
                else
                    rm -rf "$src_code_dir"
                    git clone --depth 1 ${UPSTREAM_BRANCH:+--branch "$UPSTREAM_BRANCH"} "$UPSTREAM_URL" "$src_code_dir"
                fi
            elif [[ "$UPSTREAM_URL" == *.tar.* ]]; then
                # Tarball
                local tarball="$src_dir/$(basename "$UPSTREAM_URL")"
                curl -L -o "$tarball" "$UPSTREAM_URL"
                tar -xf "$tarball" -C "$src_code_dir" --strip-components=1
                rm "$tarball"
            else
                echo -e "${RED}Unknown source type${NC}"
                return 1
            fi

            echo ""
            echo -e "${GREEN}✓ Source fetched${NC}"
            echo "  Location: $src_code_dir"
            echo "  Next: powos source patch $name  (apply patches)"
            echo "        powos source build $name  (build overlay)"
            ;;

        patch)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source patch <name>"
                return 1
            fi

            local src_dir="$SOURCES_DIR/$name"
            local patches_dir="$src_dir/patches"
            local upstream_dir="$src_dir/upstream"

            if [[ ! -d "$upstream_dir" ]]; then
                echo -e "${RED}No upstream source. Run 'powos source get $name' first.${NC}"
                return 1
            fi

            if [[ ! -d "$patches_dir" ]] || [[ -z "$(ls -A "$patches_dir" 2>/dev/null)" ]]; then
                echo "No patches to apply for $name"
                return 0
            fi

            echo -e "${CYAN}Applying patches to $name...${NC}"
            cd "$upstream_dir"

            for patch in "$patches_dir"/*.patch; do
                [[ -f "$patch" ]] || continue
                echo "  Applying: $(basename "$patch")"
                git apply "$patch" 2>/dev/null || patch -p1 < "$patch"
            done

            echo ""
            echo -e "${GREEN}✓ Patches applied${NC}"
            ;;

        build)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source build <name>"
                echo "       powos source build kde:dolphin   # Build Dolphin from KDE"
                echo ""
                echo "Build an overlay from source."
                echo "The built overlay will override the system version."
                return 1
            fi

            # Handle kde:app syntax
            local base_name="${name%%:*}"
            local app_name="${name#*:}"
            [[ "$base_name" == "$app_name" ]] && app_name=""

            local src_dir="$SOURCES_DIR/$base_name"
            local build_script="$src_dir/build.sh"
            local source_conf="$src_dir/source.conf"

            if [[ ! -f "$build_script" ]]; then
                echo -e "${RED}No build.sh for '$base_name'${NC}"
                return 1
            fi

            echo -e "${CYAN}Building $name overlay...${NC}"

            # Install build dependencies if source.conf exists
            if [[ -f "$source_conf" ]]; then
                source "$source_conf"
                if [[ -n "${BUILD_DEPS:-}" ]]; then
                    echo -e "${CYAN}Installing build dependencies...${NC}"
                    if command -v dnf &>/dev/null; then
                        sudo dnf install -y --skip-unavailable $BUILD_DEPS
                    elif command -v apt-get &>/dev/null; then
                        sudo apt-get install -y $BUILD_DEPS
                    elif command -v pacman &>/dev/null; then
                        sudo pacman -S --noconfirm --needed $BUILD_DEPS
                    fi
                    echo ""
                fi
            fi

            # Set up output directory (use app name for kde:app)
            local overlay_name="${app_name:-$base_name}"
            local output_dir="$EXTENSIONS_DIR/$overlay_name"
            mkdir -p "$output_dir/usr/bin" "$output_dir/usr/lib"

            export OVERLAY_OUTPUT_DIR="$output_dir"
            export OVERLAY_NAME="$name"

            # Run build script
            bash "$build_script" "$output_dir"

            # Create extension-release file for systemd-sysext
            local release_dir="$output_dir/usr/lib/extension-release.d"
            mkdir -p "$release_dir"
            echo "ID=fedora" > "$release_dir/extension-release.$overlay_name"

            echo ""
            echo -e "${GREEN}✓ Overlay built${NC}"
            echo "  Location: $output_dir"
            echo ""
            echo "Enable with: powos source enable $overlay_name"
            ;;

        enable)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source enable <name>"
                return 1
            fi

            local ext_dir="$EXTENSIONS_DIR/$name"
            if [[ ! -d "$ext_dir" ]]; then
                echo -e "${RED}Overlay '$name' not built. Run 'powos source build $name' first.${NC}"
                return 1
            fi

            echo -e "${CYAN}Enabling $name overlay...${NC}"

            # Link to system extensions dir
            sudo ln -sf "$ext_dir" "/var/lib/extensions/$name" 2>/dev/null || \
                ln -sf "$ext_dir" "/var/lib/extensions/$name"

            # Refresh sysext
            if command -v systemd-sysext &>/dev/null; then
                sudo systemd-sysext refresh 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Overlay enabled${NC}"
            echo "  Custom $name now overrides system version!"
            ;;

        disable)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source disable <name>"
                return 1
            fi

            echo -e "${CYAN}Disabling $name overlay...${NC}"

            sudo rm -f "/var/lib/extensions/$name" 2>/dev/null || \
                rm -f "/var/lib/extensions/$name"

            if command -v systemd-sysext &>/dev/null; then
                sudo systemd-sysext refresh 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Overlay disabled${NC}"
            echo "  System $name restored"
            ;;

        save)
            # Save local changes as patches (for backup/sharing)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source save <name>"
                echo "       powos source save kde:dolphin"
                echo ""
                echo "Saves your local edits as patch files."
                echo "Useful for backup or sharing your modifications."
                return 1
            fi

            # Handle kde:app syntax
            local base_name="${name%%:*}"
            local app_name="${name#*:}"
            [[ "$base_name" == "$app_name" ]] && app_name=""

            local src_dir="$SOURCES_DIR/$base_name"

            if [[ -n "$app_name" ]]; then
                # KDE app
                local upstream_dir="$src_dir/upstream/$app_name"
                local patches_dir="$src_dir/patches/$app_name"
            else
                # Regular source
                local upstream_dir="$src_dir/upstream"
                local patches_dir="$src_dir/patches"
            fi

            if [[ ! -d "$upstream_dir" ]]; then
                echo -e "${RED}No source found at $upstream_dir${NC}"
                return 1
            fi

            cd "$upstream_dir"

            # Check for changes
            if [[ -z "$(git status --porcelain 2>/dev/null)" ]]; then
                echo "No local changes to save."
                return 0
            fi

            mkdir -p "$patches_dir"

            # Generate patch from uncommitted changes
            local timestamp=$(date +%Y%m%d-%H%M%S)
            local patch_file="$patches_dir/local-changes-$timestamp.patch"

            echo -e "${CYAN}Saving changes to patch...${NC}"
            git diff > "$patch_file"
            git diff --staged >> "$patch_file"

            # Show what was saved
            local lines=$(wc -l < "$patch_file")
            echo -e "${GREEN}✓ Changes saved${NC}"
            echo "  Patch: $patch_file"
            echo "  Lines: $lines"
            echo ""
            echo "Your edits are preserved. You can now:"
            echo "  - Reset source: cd $upstream_dir && git checkout ."
            echo "  - Patches auto-apply on fresh builds"
            ;;

        new)
            local name="${2:-}"
            local upstream="${3:-}"

            if [[ -z "$name" ]]; then
                echo "Usage: powos source new <name> [upstream-url]"
                echo ""
                echo "Create a new source overlay template."
                echo ""
                echo "Examples:"
                echo "  powos source new myapp"
                echo "  powos source new firefox https://github.com/nicotine-plus/nicotine-plus"
                return 1
            fi

            local src_dir="$SOURCES_DIR/$name"
            if [[ -d "$src_dir" ]]; then
                echo -e "${YELLOW}Source '$name' already exists${NC}"
                return 1
            fi

            echo -e "${CYAN}Creating source template: $name${NC}"

            mkdir -p "$src_dir/patches"

            # Create source.conf
            cat > "$src_dir/source.conf" << EOF
# Source configuration for $name
# Edit this file to configure how the source is fetched and built

# Description shown in 'powos source list'
DESCRIPTION="Custom build of $name"

# Upstream source (git URL or tarball URL)
UPSTREAM_URL="${upstream:-}"

# Git branch (optional, for git sources)
UPSTREAM_BRANCH=""

# Build dependencies (space-separated)
BUILD_DEPS=""

# Runtime dependencies (space-separated)
RUNTIME_DEPS=""
EOF

            # Create build.sh template
            cat > "$src_dir/build.sh" << 'EOF'
#!/usr/bin/env bash
# build.sh - Build script for this overlay
#
# This script builds the custom version and installs to the overlay.
#
# Environment:
#   OVERLAY_OUTPUT_DIR - Where to place built files
#   OVERLAY_NAME       - Name of this overlay

set -euo pipefail

OUTPUT_DIR="${1:-$OVERLAY_OUTPUT_DIR}"
NAME="${OVERLAY_NAME:-$(basename "$(dirname "$0")")}"
SRC_DIR="$(dirname "$0")"
UPSTREAM_DIR="$SRC_DIR/upstream"

echo "Building: $NAME"
echo "Output:   $OUTPUT_DIR"
echo "Source:   $UPSTREAM_DIR"

# Create output directories
mkdir -p "$OUTPUT_DIR/usr/bin"
mkdir -p "$OUTPUT_DIR/usr/lib"
mkdir -p "$OUTPUT_DIR/usr/share/$NAME"

# Load source config if exists
[[ -f "$SRC_DIR/source.conf" ]] && source "$SRC_DIR/source.conf"

# ─────────────────────────────────────────────────────────────────
# BUILD YOUR APP HERE
# ─────────────────────────────────────────────────────────────────

if [[ -d "$UPSTREAM_DIR" ]]; then
    cd "$UPSTREAM_DIR"

    # Example: Build with make
    # make
    # make install DESTDIR="$OUTPUT_DIR" PREFIX=/usr

    # Example: Build with cmake
    # mkdir -p build && cd build
    # cmake .. -DCMAKE_INSTALL_PREFIX=/usr
    # make
    # make install DESTDIR="$OUTPUT_DIR"

    # Example: Build with meson
    # meson setup build --prefix=/usr
    # meson compile -C build
    # meson install -C build --destdir="$OUTPUT_DIR"

    # Example: Copy pre-built binary
    # cp ./target/release/myapp "$OUTPUT_DIR/usr/bin/"

    echo "TODO: Add build commands for $NAME"
else
    echo "No upstream source found. Run 'powos source get $NAME' first."
    echo "Or add build commands that don't require upstream source."
fi

echo "✅ Built: $NAME"
EOF

            chmod +x "$src_dir/build.sh"

            # Create README
            cat > "$src_dir/README.md" << EOF
# $name Source Overlay

Custom build of $name for PowOS.

## Quick Start

\`\`\`bash
# Fetch upstream source
powos source get $name

# Apply patches (if any)
powos source patch $name

# Build the overlay
powos source build $name

# Enable it (overrides system version)
powos source enable $name
\`\`\`

## Adding Patches

Put \`.patch\` files in the \`patches/\` directory.
They'll be applied in alphabetical order.

\`\`\`bash
# Create a patch from your changes
cd upstream
git diff > ../patches/01-my-feature.patch
\`\`\`

## Files

- \`source.conf\` - Source configuration
- \`build.sh\` - Build script
- \`patches/\` - Patches to apply
- \`upstream/\` - Fetched source code (git-ignored)
EOF

            echo ""
            echo -e "${GREEN}✓ Source template created${NC}"
            echo "  Location: $src_dir"
            echo ""
            echo "Next steps:"
            echo "  1. Edit $src_dir/source.conf (set UPSTREAM_URL)"
            echo "  2. Edit $src_dir/build.sh (add build commands)"
            echo "  3. powos source get $name"
            echo "  4. powos source build $name"
            echo "  5. powos source enable $name"
            ;;

        *)
            echo "Usage: powos source <command>"
            echo ""
            echo "Manage source overlays - build custom versions of apps."
            echo ""
            echo "Commands:"
            echo "  list                  List available sources"
            echo "  new <name> [url]      Create new source template"
            echo "  get <name>            Fetch upstream source code"
            echo "  patch <name>          Apply patches to source"
            echo "  build <name>          Build overlay from source"
            echo "  enable <name>         Enable overlay (overrides system)"
            echo "  disable <name>        Disable overlay (restore system)"
            echo ""
            echo "Examples:"
            echo "  powos source new myapp https://github.com/user/myapp"
            echo "  powos source get myapp"
            echo "  powos source build myapp"
            echo "  powos source enable myapp"
            echo ""
            echo "How it works:"
            echo "  1. Source code lives in sources/<name>/"
            echo "  2. Patches in sources/<name>/patches/ are applied"
            echo "  3. build.sh compiles and installs to extensions/<name>/"
            echo "  4. systemd-sysext merges extension over system files"
            echo "  5. Your custom build overrides the system version!"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Container Commands (Podman/Distrobox)
# ═══════════════════════════════════════════════════════════════════

cmd_containers() {
    local action="${1:-list}"
    local DISTROBOX_CONFIG="/etc/powos/containers/distrobox.ini"

    case "$action" in
        list|ls)
            echo -e "${BOLD}${CYAN}Containers${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Show Distrobox containers
            echo -e "${CYAN}Distrobox Containers:${NC}"
            if command -v distrobox &>/dev/null; then
                distrobox list 2>/dev/null || echo "  (none created yet)"
            else
                echo "  distrobox not installed"
            fi
            echo ""

            # Show Podman containers
            echo -e "${CYAN}Podman Containers:${NC}"
            if command -v podman &>/dev/null; then
                podman ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Image}}" 2>/dev/null || echo "  (none)"
            else
                echo "  podman not installed"
            fi
            echo ""

            # Show images
            echo -e "${CYAN}Images:${NC}"
            if command -v podman &>/dev/null; then
                podman images --format "table {{.Repository}}\t{{.Tag}}\t{{.Size}}" 2>/dev/null | head -10
                local count
                count=$(podman images -q 2>/dev/null | wc -l)
                if [[ "$count" -gt 10 ]]; then
                    echo "  ... and $((count - 10)) more"
                fi
            fi
            ;;

        create)
            local name="${2:-}"
            local image="${3:-}"

            if [[ -z "$name" ]]; then
                echo "Usage: powos containers create <name> [image]"
                echo ""
                echo "Examples:"
                echo "  powos containers create dev              # Default Fedora container"
                echo "  powos containers create arch archlinux   # Arch Linux container"
                echo "  powos containers create ubuntu ubuntu:22.04"
                echo ""
                echo "Predefined containers (from distrobox.ini):"
                echo "  powos containers assemble                # Create all predefined"
                return 1
            fi

            image="${image:-fedora:latest}"
            echo "Creating distrobox container: $name (image: $image)"
            distrobox create --name "$name" --image "$image" --yes
            echo ""
            echo -e "${GREEN}✓ Container '$name' created${NC}"
            echo "  Enter with: powos containers enter $name"
            ;;

        enter)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos containers enter <name>"
                echo ""
                echo "Available containers:"
                distrobox list 2>/dev/null || echo "  (none)"
                return 1
            fi
            distrobox enter "$name"
            ;;

        remove|rm)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos containers remove <name>"
                return 1
            fi
            echo "Removing container: $name"
            distrobox rm "$name" --yes
            echo -e "${GREEN}✓ Container '$name' removed${NC}"
            ;;

        stop)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos containers stop <name>"
                return 1
            fi
            distrobox stop "$name" --yes
            echo -e "${GREEN}✓ Container '$name' stopped${NC}"
            ;;

        assemble)
            echo -e "${BOLD}${CYAN}Creating Predefined Containers${NC}"
            echo "════════════════════════════════════════"
            echo ""

            local config_file=""
            # Find distrobox.ini
            for path in "$DISTROBOX_CONFIG" "/var/lib/powos/containers/distrobox.ini" "containers/distrobox.ini"; do
                if [[ -f "$path" ]]; then
                    config_file="$path"
                    break
                fi
            done

            if [[ -z "$config_file" ]]; then
                echo -e "${YELLOW}No distrobox.ini found${NC}"
                echo "Create one at: containers/distrobox.ini"
                return 1
            fi

            echo "Using config: $config_file"
            echo ""
            distrobox assemble create --file "$config_file"
            echo ""
            echo -e "${GREEN}✓ Predefined containers created${NC}"
            ;;

        export)
            local name="${2:-}"
            local app="${3:-}"
            if [[ -z "$name" ]] || [[ -z "$app" ]]; then
                echo "Usage: powos containers export <container> <app>"
                echo ""
                echo "Export an app from a container to the host menu"
                echo "Example: powos containers export arch-dev code"
                return 1
            fi
            distrobox-export --app "$app" --container "$name"
            echo -e "${GREEN}✓ Exported '$app' from '$name'${NC}"
            ;;

        podman)
            # Pass through to podman
            shift
            podman "$@"
            ;;

        prune)
            echo "Cleaning up unused container resources..."
            podman system prune -f
            echo -e "${GREEN}✓ Cleanup complete${NC}"
            ;;

        *)
            echo "Usage: powos containers <command>"
            echo ""
            echo "Commands:"
            echo "  list                    List all containers and images"
            echo "  create <name> [image]   Create a new distrobox container"
            echo "  enter <name>            Enter a distrobox container"
            echo "  stop <name>             Stop a container"
            echo "  remove <name>           Remove a container"
            echo "  assemble                Create all predefined containers"
            echo "  export <name> <app>     Export app from container to host"
            echo "  prune                   Clean up unused resources"
            echo "  podman <args>           Pass through to podman"
            echo ""
            echo "Examples:"
            echo "  powos containers create dev"
            echo "  powos containers enter dev"
            echo "  powos containers assemble"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Main Dispatch
# ═══════════════════════════════════════════════════════════════════

case "${1:-}" in
    status)
        cmd_status
        ;;
    sync)
        cmd_sync
        ;;
    safe)
        cmd_safe
        ;;
    layers)
        shift
        cmd_layers "$@"
        ;;
    rollback)
        shift
        cmd_rollback "$@"
        ;;
    update)
        shift
        cmd_update "$@"
        ;;
    hardware)
        cmd_hardware
        ;;
    profile)
        cmd_hardware | grep ACTIVE_PROFILE
        ;;
    containers|container|c)
        shift
        cmd_containers "$@"
        ;;
    install|i)
        shift
        cmd_install "$@"
        ;;
    build|b)
        shift
        cmd_build "$@"
        ;;
    dev|d)
        shift
        cmd_dev "$@"
        ;;
    source|src|s)
        # Deprecated - redirect to dev
        echo -e "${YELLOW}Note: 'powos source' is deprecated. Use 'powos dev' instead.${NC}"
        shift
        cmd_dev "$@"
        ;;
    version|--version|-v)
        cmd_version
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'powos help' for usage"
        exit 1
        ;;
esac
