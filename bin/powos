#!/bin/bash
# powos - PowOS CLI
#
# Main command interface for PowOS system management.

set -e

VERSION="0.2.0"
OVERLAY_SCRIPT="/usr/lib/powos/ramfs/overlay-mount.sh"
SYNC_DAEMON="/usr/lib/powos/ramfs/sync-daemon.py"

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
NC='\033[0m'

usage() {
    cat << EOF
PowOS - Portable Gaming Workstation

Usage: powos <command> [options]

Commands:
  status          Show system status (USB, overlay, sync)
  sync            Force sync RAM changes to USB
  safe            Check if safe to unplug USB

  overlay status  Show overlay details
  overlay sync    Sync overlays to USB

  hardware        Show detected hardware
  profile         Show active hardware profile

  version         Show version

Examples:
  powos status              # Quick status check
  powos sync                # Force sync now
  powos safe && echo "OK"   # Check before unplugging

EOF
}

# Get USB status
get_usb_status() {
    if [[ -f /run/powos/usb-state ]]; then
        source /run/powos/usb-state
        echo "$USB_STATUS"
    else
        echo "unknown"
    fi
}

# Get RAM overlay usage
get_ram_usage() {
    if mountpoint -q /run/powos/overlay 2>/dev/null; then
        df -h /run/powos/overlay | tail -1 | awk '{print $3 "/" $2}'
    else
        echo "N/A"
    fi
}

# Check if safe to unplug
is_safe_to_unplug() {
    # Check sync status
    if [[ -f /run/powos/sync-status ]]; then
        local pending
        pending=$(python3 -c "import json; print(json.load(open('/run/powos/sync-status')).get('pending_changes', 0))" 2>/dev/null || echo "0")
        [[ "$pending" == "0" ]]
    else
        return 0
    fi
}

# Check if running in full ramboot mode
is_ramboot() {
    [[ -f /run/powos/ramboot-state ]]
}

# Get ramboot info
get_ramboot_info() {
    if [[ -f /run/powos/ramboot-state ]]; then
        source /run/powos/ramboot-state
        echo "$POWOS_RAM_SIZE"
    else
        echo "N/A"
    fi
}

# Check if CacheFS is running
is_cachefs_active() {
    mountpoint -q /home/powos 2>/dev/null && \
        [[ -f /run/powos/cachefs-status.json ]]
}

# Get CacheFS info
get_cachefs_info() {
    if [[ -f /run/powos/cachefs-status.json ]]; then
        python3 -c "
import json
try:
    s = json.load(open('/run/powos/cachefs-status.json'))
    print(f\"USB: {'Connected' if s.get('usb_connected') else 'Disconnected'}\")
    print(f\"Pending: {s.get('pending_changes', 0)} files\")
except: pass
" 2>/dev/null
    fi
}

# Status command
cmd_status() {
    echo -e "${CYAN}PowOS Status${NC}"
    echo "============"
    echo ""

    # === OS Status ===
    echo -e "${CYAN}Operating System${NC}"
    if is_ramboot; then
        echo -e "  Mode:       ${GREEN}● FULL RAM BOOT${NC}"
        echo "              Entire OS running from RAM"
        local ram_size
        ram_size=$(get_ramboot_info)
        echo "  RAM:        $ram_size allocated"
        if [[ -d /run/powos-overlay/upper ]]; then
            local upper_used
            upper_used=$(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo "0")
            echo "  Used:       $upper_used (changes since boot)"
        fi
    else
        echo -e "  Mode:       ${YELLOW}○ Standard${NC}"
        echo "              OS running from USB (not in RAM)"
    fi
    echo ""

    # === User Data Status ===
    echo -e "${CYAN}User Data (/home)${NC}"
    if is_cachefs_active; then
        echo -e "  Mode:       ${GREEN}● CacheFS (lazy-load)${NC}"
        echo "              Files load on-demand, cached in RAM"
        get_cachefs_info | while read -r line; do echo "  $line"; done

        # Show cache usage
        if [[ -d /run/powos/cachefs ]]; then
            local cache_used
            cache_used=$(du -sh /run/powos/cachefs 2>/dev/null | cut -f1 || echo "0")
            echo "  Cache:      $cache_used in RAM"
        fi
    elif mountpoint -q /home/powos 2>/dev/null; then
        echo -e "  Mode:       ${CYAN}○ Direct${NC}"
        echo "              USB mounted directly (no caching)"
    else
        echo -e "  Mode:       ${YELLOW}○ tmpfs${NC}"
        echo "              Temporary (no USB detected)"
    fi
    echo ""

    # === USB Status ===
    echo -e "${CYAN}USB Drive${NC}"
    local usb_status
    usb_status=$(get_usb_status)
    case "$usb_status" in
        connected)
            echo -e "  Status:     ${GREEN}● Connected${NC}"
            ;;
        disconnected)
            echo -e "  Status:     ${YELLOW}○ Disconnected${NC}"
            if is_ramboot || is_cachefs_active; then
                echo "              (cached data still accessible)"
            fi
            ;;
        *)
            echo -e "  Status:     ${RED}? Unknown${NC}"
            ;;
    esac

    # Sync Status
    if [[ -f /run/powos/cachefs-status.json ]] || [[ -f /run/powos/sync-status ]]; then
        local last_sync
        last_sync=$(python3 -c "
import json, time
for f in ['/run/powos/cachefs-status.json', '/run/powos/sync-status']:
    try:
        s = json.load(open(f))
        t = s.get('last_sync', 0)
        if t > 0:
            delta = int(time.time() - t)
            if delta < 60:
                print(f'{delta}s ago')
            elif delta < 3600:
                print(f'{delta // 60}m ago')
            else:
                print(f'{delta // 3600}h ago')
            break
    except: pass
else:
    print('Never')
" 2>/dev/null || echo "Unknown")
        echo "  Last Sync:  $last_sync"
    fi
    echo ""

    # === Summary ===
    echo -e "${CYAN}Unplug Safety${NC}"
    if is_ramboot && is_cachefs_active; then
        echo -e "  ${GREEN}✓ FULLY PROTECTED${NC}"
        echo "    OS: in RAM, User data: cached"
        echo "    USB can be unplugged anytime!"
    elif is_ramboot; then
        echo -e "  ${GREEN}✓ OS Protected${NC}"
        echo "    OS in RAM, but user data may need USB"
    elif is_cachefs_active; then
        echo -e "  ${CYAN}◐ Partially Protected${NC}"
        echo "    User data cached, OS still needs USB"
    else
        echo -e "  ${RED}✗ Not Protected${NC}"
        echo "    USB required for operation"
    fi
    echo ""
}

# Sync command
cmd_sync() {
    echo "Syncing to USB..."

    if [[ -x "$OVERLAY_SCRIPT" ]]; then
        "$OVERLAY_SCRIPT" sync
    else
        # Fallback
        bash /usr/lib/powos/ramfs/overlay-mount.sh sync 2>/dev/null || \
            echo "Overlay script not available"
    fi
}

# Safe check command
cmd_safe() {
    if is_safe_to_unplug; then
        echo -e "${GREEN}✓ Safe to unplug USB${NC}"
        exit 0
    else
        echo -e "${RED}✗ Not safe - sync in progress${NC}"
        exit 1
    fi
}

# Hardware command
cmd_hardware() {
    if [[ -f /run/powos/hardware ]]; then
        cat /run/powos/hardware
    else
        echo "Hardware not detected yet"
    fi
}

# Version command
cmd_version() {
    echo "PowOS version $VERSION"
}

# Overlay subcommand
cmd_overlay() {
    case "${1:-status}" in
        status)
            if [[ -x "$OVERLAY_SCRIPT" ]]; then
                "$OVERLAY_SCRIPT" status
            else
                bash /usr/lib/powos/ramfs/overlay-mount.sh status 2>/dev/null || \
                    echo "Overlay script not available"
            fi
            ;;
        sync)
            cmd_sync
            ;;
        *)
            echo "Usage: powos overlay {status|sync}"
            ;;
    esac
}

# Main dispatch
case "${1:-}" in
    status)
        cmd_status
        ;;
    sync)
        cmd_sync
        ;;
    safe)
        cmd_safe
        ;;
    overlay)
        shift
        cmd_overlay "$@"
        ;;
    hardware)
        cmd_hardware
        ;;
    profile)
        cmd_hardware | grep ACTIVE_PROFILE
        ;;
    version|--version|-v)
        cmd_version
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'powos help' for usage"
        exit 1
        ;;
esac
