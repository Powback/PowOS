#!/bin/bash
# powos - PowOS CLI
#
# Main command interface for PowOS system management.

set -e

VERSION="0.3.0"
LAYER_SYNC="/usr/lib/powos/ramfs/layer-sync.py"
STATE_DIR="/run/powos"

# Location of PowOS shell libraries. Installed image ships them in
# /usr/lib/powos; fall back to the repo's lib/ for dev/Docker runs.
POWOS_LIB="/usr/lib/powos"
[[ -f "$POWOS_LIB/hardware-detect.sh" ]] || POWOS_LIB="$(cd "$(dirname "$0")/../lib" && pwd)"

GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
RED='\033[0;31m'
BOLD='\033[1m'
NC='\033[0m'

# One-line notice for EXPERIMENTAL (unvalidated) commands. These are half-built
# or hardware-only features kept in the tree but NOT part of the primary
# install-to-disk story. Warn on stderr so piped/scripted stdout is unaffected.
experimental_warn() {
    echo -e "${YELLOW}⚠ '$1' is EXPERIMENTAL (unvalidated — may not work as described).${NC}" >&2
    echo -e "${YELLOW}  See the Feature Status table in CLAUDE.md.${NC}" >&2
}

usage() {
    cat << EOF
PowOS - Install-to-disk daily-driver that dual-boots Windows

Usage: powos <command> [options]

Tip: run 'powos menu' for a guided, categorized menu of everything below.

═══ CORE COMMANDS ═══════════════════════════════════════════════════

Discover & status:
  menu                Guided interactive menu (discoverable front door)
  overview            One-glance panel: model, image, GPU/CUDA, deploys, disk
  overview --json     Same, machine-readable (for widgets/plasmoids)
  services            Running containers + container services + GPU users
  status              Show full system status
  health              System health check (layers, RAM, USB, sync)
  health --ai         Talk to health AI agent for troubleshooting
  doctor              Collect a boot diagnostic bundle → /var/log/powos/
  doctor --ai         + have the health agent diagnose it
  hardware            Show detected hardware
  profile             Show active hardware profile
  version             Show version

Install to disk (dual-boot Windows) — the primary path:
  install <thing>     Find it everywhere, install the most CONTAINED way
                      (flatpak → sandbox container → asks before touching OS)
  install -m <be> <p> Force backend: flatpak|sandbox|brew|pip|container|host
  install --dry <p>   Show where it was found + routing, install nothing
  install -c NAME <pkg>  Install package to container NAME
  install -c NAME -e <pkg>  Install GUI app to container + export to host
  install-system      Install PowOS to an internal disk (interactive)
  install-system --alongside   Dual-boot: install into free space, keep Windows
  install-system --whole-disk  Erase target disk (requires confirmation)
  install-system --dry-run     Show the plan, change nothing
  games status        Shared NTFS games partition (with Windows) — state
  games create --size N        Create POWOS-GAMES (plan + confirm + --dry-run)
  games steam-setup   Put a Steam library on the shared partition

Boot / dual-boot:
  boot list           Show UEFI boot entries
  boot windows        Reboot into bare-metal Windows once (anti-cheat games), then back
  boot next <name>    One-shot boot into any UEFI entry by name
  base list           List OS base variants (● = active)
  base switch <name>  Boot into a different base next reboot (nvidia-open/nvidia/main)
  driver status       Show current NVIDIA driver channel (image tag)
  driver stable       Switch to tested drivers (:nvidia-open), reboot to apply

  cuda enable         Set up the CUDA toolkit in a GPU-passthrough container
  cuda status         Container / toolkit / GPU visibility

Sync, flush & backup:
  sync                Sync RAM ↔ USB (with conflict detection)
  sync status         Show sync status (pending changes, conflicts)
  sync resolve [--ai] Resolve conflicts interactively (--ai for help)
  sync --keep-ram     Force RAM changes to USB (your work wins)
  sync --keep-usb     Reload from USB (USB wins)
  flush               Force flush RAM → USB (no conflict check)
  safe                Check if safe to unplug USB
  backup [status|push|pull|setup <url>]  Backup system state to cloud (git)

Update & self (edit → test → push loop):
  update              Check for available updates
  update os           Update Bazzite base OS (bootc upgrade; 'upgrade' is smarter)
  update packages     Update installed packages
  update apply        Apply all updates (os + packages)
  upgrade             Pull+stage a base update, apply the lightest restart
  upgrade --check     Just check if a base update is available
  reload              Apply your local PowOS changes LIVE (no reboot)
  reload --pull       git pull the checkout first, then apply
  reload --build      Full local image build + switch (base/package changes)
  self status         Edit-loop: baked commit, git attach state, local edits
  self test           Apply local /var/lib/powos/src edits to THIS system (transient)
  self pull           SAFE update from upstream (never discards local edits)
  self push           git add -A + commit + push (-m "message")

Layers & rollback:
  layers              Show active layers
  layers status       Detailed layer status
  layers sync         Sync RAM to custom layer now
  layers clear custom|updates  Clear a layer entirely
  rollback            Show rollback options
  rollback custom|updates|all  Boot without a layer / base only (next boot)
  rollback reset      Clear rollback flags

Packages, containers & build:
  containers          List containers and images
  containers create   Create a new distrobox container
  containers enter    Enter a distrobox container
  containers assemble Create all predefined containers
  containers prune    Clean up unused resources
  build [path] [tag]  Build container from Dockerfile/Containerfile
  build iso           Build the bootable PowOS image
  build test          Build container image only (for testing)
  build image [variant] [--switch]  Build the OS image LOCALLY (no GitHub)
  registry login [host]   Save pull creds for private images (default ghcr.io)

Dev & AI:
  dev                 List all dev projects
  dev new <name>      Create new project from scratch
  dev fork <upstream> Fork existing app (e.g., kde:dolphin)
  dev build|enable|disable <name>  Build / install (overlay) / remove a project
  dev update <name>   Pull upstream changes (forks only)
  ai "prompt"         Ask AI for help (uses default agent)
  ai --agent coder|devops|health   Pick an agent
  ai -i               Interactive chat mode
  ai --session <id>   Resume a conversation

═══ EXPERIMENTAL (unvalidated — may not work) ═══════════════════════
These features are half-built or hardware-only and are NOT part of the
primary install-to-disk story. They print a warning when run. See the
Feature Status table in CLAUDE.md before relying on them.

  ramboot status     OS-in-RAM opt-in (installed): mode, RAM-vs-OS fit
  ramboot enable     Copy the OS to tmpfs (composefs-safe opt-in; installed only)
  ramboot disable    Remove the installed OS-in-RAM opt-in kargs
  mobile             Mobile mode: copy OS to RAM (WIP — needs reboot to activate)
  windows status     Bare-metal Windows in a VHDX (experimental)
  windows create|install|finalize|vm   VHDX lifecycle (not hardware-validated)
  vm status          Show installed OSes bootable as a VM
  vm windows         Boot installed Windows as a KVM guest (no reboot; non-AC only)
  gpu status         Where the dGPU is (host vs VM) + passthrough readiness
  gpu to-vm|to-host  Hotswap the dGPU between Linux (CUDA) and a VM
  (CacheFS — lazy-load /home — remains DISABLED: write-back to USB not implemented)

Examples:
  powos status                        # Quick status check
  powos sync                          # Smart sync with remote
  powos sync push -m "backup"         # Push with message
  powos flush                         # Force RAM → USB now
  powos update os                     # Update Bazzite
  powos update powos                  # Update PowOS scripts

  powos install neovim htop           # Install to host
  powos install -c dev nodejs npm     # Install to 'dev' container
  powos install -c arch -e firefox    # Install Firefox in Arch, export to host menu

  # Create a new app:
  powos dev new myapp
  cd /var/lib/powos/projects/myapp/src
  # write code
  powos dev build myapp
  powos dev enable myapp

  # Customize KDE apps:
  powos dev fork kde:dolphin
  cd /var/lib/powos/projects/dolphin/src
  # edit files
  powos dev build dolphin
  powos dev enable dolphin

  powos containers create dev         # Create Fedora dev container
  powos containers enter dev          # Enter the container
  powos build . myapp:latest          # Build from Dockerfile

EOF
}

# ═══════════════════════════════════════════════════════════════════
# Utility Functions
# ═══════════════════════════════════════════════════════════════════

# Get USB status
get_usb_status() {
    if [[ -f "$STATE_DIR/usb-state" ]]; then
        source "$STATE_DIR/usb-state"
        echo "$USB_STATUS"
    else
        echo "unknown"
    fi
}

# Check if running in full ramboot mode
is_ramboot() {
    [[ -f "$STATE_DIR/ramboot-state" ]]
}

# Get ramboot info
get_ramboot_info() {
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        echo "$POWOS_RAM_SIZE"
    else
        echo "N/A"
    fi
}

# Get active layers
get_active_layers() {
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        echo "$POWOS_LAYERS_ACTIVE"
    else
        echo "none"
    fi
}

# Check if CacheFS is running
is_cachefs_active() {
    mountpoint -q /home/powos 2>/dev/null && \
        [[ -f "$STATE_DIR/cachefs-status.json" ]]
}

# Check if safe to unplug
is_safe_to_unplug() {
    local pending=0
    for status_file in "$STATE_DIR/layer-sync-status.json" "$STATE_DIR/cachefs-status.json"; do
        if [[ -f "$status_file" ]]; then
            local p
            p=$(python3 -c "import json; print(json.load(open('$status_file')).get('pending_changes', 0))" 2>/dev/null || echo "0")
            pending=$((pending + p))
        fi
    done
    [[ "$pending" == "0" ]]
}

# ═══════════════════════════════════════════════════════════════════
# Status Command
# ═══════════════════════════════════════════════════════════════════

cmd_status() {
    echo -e "${BOLD}${CYAN}PowOS Status${NC}"
    echo "════════════════════════════════════════"
    echo ""

    # === Layers ===
    echo -e "${CYAN}Active Layers${NC}"
    local layers
    layers=$(get_active_layers)
    if [[ "$layers" != "none" ]]; then
        echo -e "  Stack:      ${GREEN}$layers${NC}"
        # Parse and show each layer
        IFS=',' read -ra LAYER_ARR <<< "$layers"
        for layer in "${LAYER_ARR[@]}"; do
            case "$layer" in
                custom)
                    echo -e "              ├─ ${GREEN}●${NC} custom (your packages & configs)"
                    ;;
                updates)
                    echo -e "              ├─ ${GREEN}●${NC} updates (OS updates)"
                    ;;
                base)
                    echo -e "              └─ ${GREEN}●${NC} base (Bazzite)"
                    ;;
            esac
        done
    else
        echo -e "  Stack:      ${YELLOW}Standard boot (no layers)${NC}"
    fi

    # Check for skipped layers
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        if [[ "$POWOS_SKIP_CUSTOM" == "1" ]]; then
            echo -e "  ${YELLOW}⚠ Custom layer SKIPPED (rollback active)${NC}"
        fi
        if [[ "$POWOS_SKIP_UPDATES" == "1" ]]; then
            echo -e "  ${YELLOW}⚠ Updates layer SKIPPED (rollback active)${NC}"
        fi
    fi
    echo ""

    # === RAM Status ===
    echo -e "${CYAN}RAM Overlay${NC}"
    if is_ramboot; then
        echo -e "  Mode:       ${GREEN}● Running from RAM${NC}"
        local ram_size
        ram_size=$(get_ramboot_info)
        echo "  Allocated:  $ram_size"
        if [[ -d /run/powos-overlay/upper ]]; then
            local upper_used
            upper_used=$(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo "0")
            echo "  Used:       $upper_used (changes since boot)"
        fi
    else
        echo -e "  Mode:       ${YELLOW}○ Standard (no RAM overlay)${NC}"
    fi
    echo ""

    # === User Data ===
    echo -e "${CYAN}User Data (/home)${NC}"
    if is_cachefs_active; then
        echo -e "  Mode:       ${GREEN}● CacheFS (lazy-load)${NC}"
        if [[ -f "$STATE_DIR/cachefs-status.json" ]]; then
            python3 -c "
import json
s = json.load(open('$STATE_DIR/cachefs-status.json'))
print(f\"  USB:        {'Connected' if s.get('usb_connected') else 'Disconnected'}\")
print(f\"  Cached:     {s.get('cached_files', 0)} files\")
" 2>/dev/null || true
        fi
    elif mountpoint -q /home/powos 2>/dev/null; then
        echo -e "  Mode:       ${CYAN}○ Direct USB${NC}"
    else
        echo -e "  Mode:       ${YELLOW}○ tmpfs (temporary)${NC}"
    fi
    echo ""

    # === USB Status ===
    echo -e "${CYAN}USB Drive${NC}"
    local usb_status
    usb_status=$(get_usb_status)
    case "$usb_status" in
        connected)
            echo -e "  Status:     ${GREEN}● Connected${NC}"
            ;;
        disconnected)
            echo -e "  Status:     ${YELLOW}○ Disconnected${NC}"
            ;;
        *)
            echo -e "  Status:     ${RED}? Unknown${NC}"
            ;;
    esac

    # Last sync
    if [[ -f "$STATE_DIR/layer-sync-status.json" ]]; then
        local last_sync
        last_sync=$(python3 -c "
import json, time
s = json.load(open('$STATE_DIR/layer-sync-status.json'))
t = s.get('last_sync', 0)
if t > 0:
    delta = int(time.time() - t)
    if delta < 60: print(f'{delta}s ago')
    elif delta < 3600: print(f'{delta // 60}m ago')
    else: print(f'{delta // 3600}h ago')
else: print('Never')
" 2>/dev/null || echo "Unknown")
        echo "  Last Sync:  $last_sync"
    fi
    echo ""

    # === Protection Summary ===
    echo -e "${CYAN}Unplug Safety${NC}"
    if is_ramboot && is_cachefs_active; then
        echo -e "  ${GREEN}✓ FULLY PROTECTED${NC}"
        echo "    OS in RAM, user data cached"
        echo "    USB can be unplugged anytime!"
    elif is_ramboot; then
        echo -e "  ${GREEN}✓ OS Protected${NC}"
        echo "    OS in RAM, user data may need USB"
    elif is_cachefs_active; then
        echo -e "  ${CYAN}◐ Partial${NC}"
        echo "    User data cached, OS needs USB"
    else
        echo -e "  ${RED}✗ Not Protected${NC}"
        echo "    USB required for operation"
    fi
    echo ""
}

# ═══════════════════════════════════════════════════════════════════
# Layers Command
# ═══════════════════════════════════════════════════════════════════

cmd_layers() {
    local subcmd="${1:-status}"

    case "$subcmd" in
        status)
            echo -e "${BOLD}${CYAN}Layer Stack${NC}"
            echo "════════════════════════════════════════"
            echo ""
            echo "  Writes → [RAM Upper] → sync → [Custom Layer] → USB"
            echo ""
            echo "  Lower layers (read-only at runtime):"

            local layers
            layers=$(get_active_layers)

            # Custom layer
            if [[ "$layers" == *"custom"* ]]; then
                echo -e "    ${GREEN}●${NC} custom    - Your packages, configs, customizations"
                if [[ -d /run/powos/usb-layers/layers/custom ]]; then
                    local size
                    size=$(du -sh /run/powos/usb-layers/layers/custom 2>/dev/null | cut -f1 || echo "empty")
                    echo "                  Size: $size"
                fi
            else
                echo -e "    ${YELLOW}○${NC} custom    - (empty or skipped)"
            fi

            # Updates layer
            if [[ "$layers" == *"updates"* ]]; then
                echo -e "    ${GREEN}●${NC} updates   - OS updates"
                if [[ -d /run/powos/usb-layers/layers/updates ]]; then
                    local size
                    size=$(du -sh /run/powos/usb-layers/layers/updates 2>/dev/null | cut -f1 || echo "empty")
                    echo "                  Size: $size"
                fi
            else
                echo -e "    ${YELLOW}○${NC} updates   - (empty or skipped)"
            fi

            # Base layer
            echo -e "    ${GREEN}●${NC} base      - Bazzite OS image"
            echo ""

            # RAM upper stats
            echo "  RAM Upper (writes since boot):"
            if [[ -d /run/powos-overlay/upper ]]; then
                local files count size
                count=$(find /run/powos-overlay/upper -type f 2>/dev/null | wc -l)
                size=$(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo "0")
                echo "    Files changed: $count"
                echo "    Size: $size"
            else
                echo "    (not available)"
            fi
            echo ""
            ;;

        sync)
            echo "Syncing RAM changes to custom layer..."
            if [[ -x "$LAYER_SYNC" ]]; then
                python3 "$LAYER_SYNC" --sync-now
            else
                echo "Layer sync not available"
                exit 1
            fi
            ;;

        clear)
            local layer="${2:-}"
            case "$layer" in
                custom)
                    echo -e "${YELLOW}Clearing custom layer...${NC}"
                    if [[ "$(get_usb_status)" != "connected" ]]; then
                        echo -e "${RED}Error: USB not connected${NC}"
                        exit 1
                    fi
                    local custom_path="/run/powos/usb-layers/layers/custom"
                    if [[ -d "$custom_path" ]]; then
                        rm -rf "${custom_path:?}"/*
                        echo -e "${GREEN}✓ Custom layer cleared${NC}"
                        echo "  Your customizations will be gone on next boot"
                        echo "  Current session still has changes in RAM"
                    else
                        echo "Custom layer path not found"
                        exit 1
                    fi
                    ;;
                updates)
                    echo -e "${YELLOW}Clearing updates layer...${NC}"
                    if [[ "$(get_usb_status)" != "connected" ]]; then
                        echo -e "${RED}Error: USB not connected${NC}"
                        exit 1
                    fi
                    local updates_path="/run/powos/usb-layers/layers/updates"
                    if [[ -d "$updates_path" ]]; then
                        rm -rf "${updates_path:?}"/*
                        echo -e "${GREEN}✓ Updates layer cleared${NC}"
                        echo "  OS updates will be gone on next boot"
                    else
                        echo "Updates layer path not found"
                        exit 1
                    fi
                    ;;
                *)
                    echo "Usage: powos layers clear {custom|updates}"
                    echo ""
                    echo "  custom   - Clear your packages, configs, customizations"
                    echo "  updates  - Clear OS updates"
                    ;;
            esac
            ;;

        *)
            echo "Usage: powos layers {status|sync|clear}"
            echo ""
            echo "  status              - Show layer stack"
            echo "  sync                - Force sync RAM to custom layer"
            echo "  clear custom        - Clear custom layer"
            echo "  clear updates       - Clear updates layer"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Rollback Command
# ═══════════════════════════════════════════════════════════════════

# Print manual instructions for applying/removing rollback kernel args
_rollback_manual_help() {
    local mode="$1"   # add|remove
    local kargs="$2"
    echo "" >&2
    echo "Apply the change manually with one of:" >&2
    if [[ "$mode" == "add" ]]; then
        echo "  sudo bootc kargs --append-if-missing='<karg>'   (one per karg: $kargs)" >&2
        echo "  or edit the BLS entry in /boot/loader/entries/ and append: $kargs" >&2
    else
        echo "  sudo bootc kargs --delete='<karg>'   (one per karg: $kargs)" >&2
        echo "  or edit the BLS entry in /boot/loader/entries/ and remove: $kargs" >&2
    fi
}

# Update kernel args for the next boot via grubby.
# Returns non-zero (with a clear FAILED message + grubby's stderr) when the
# boot entry could not be updated — no silent success.
_rollback_apply_kargs() {
    local mode="$1"   # add|remove
    shift
    local kargs="$*"

    if ! command -v grubby &>/dev/null; then
        echo -e "${RED}✗ FAILED: 'grubby' not found — boot entry NOT updated${NC}" >&2
        _rollback_manual_help "$mode" "$kargs"
        return 1
    fi

    local out rc=0
    if [[ "$mode" == "add" ]]; then
        out=$(grubby --update-kernel=ALL --args="$kargs" 2>&1) || rc=$?
    else
        out=$(grubby --update-kernel=ALL --remove-args="$kargs" 2>&1) || rc=$?
    fi

    if [[ $rc -ne 0 ]]; then
        echo -e "${RED}✗ FAILED: grubby exited with code $rc — boot entry NOT updated${NC}" >&2
        [[ -n "$out" ]] && echo "$out" >&2
        _rollback_manual_help "$mode" "$kargs"
        return 1
    fi

    return 0
}

cmd_rollback() {
    local target="${1:-}"
    local KARGS_FILE="/run/powos/rollback-kargs"

    case "$target" in
        "")
            echo -e "${BOLD}${CYAN}Rollback Options${NC}"
            echo "════════════════════════════════════════"
            echo ""
            echo "Rollback allows you to boot without specific layers."
            echo "Useful when an update or customization breaks something."
            echo ""
            echo "Commands:"
            echo "  powos rollback custom   - Skip custom layer (next boot)"
            echo "  powos rollback updates  - Skip updates layer (next boot)"
            echo "  powos rollback all      - Boot base only (next boot)"
            echo "  powos rollback reset    - Clear rollback flags"
            echo ""

            # Show current rollback state
            if [[ -f "$KARGS_FILE" ]]; then
                echo -e "${YELLOW}Rollback flags requested this boot (informational record only):${NC}"
                cat "$KARGS_FILE"
                echo "  Verify the boot entry actually changed: grubby --info=DEFAULT"
                echo ""
            fi

            # Show what layers are currently skipped
            if [[ -f "$STATE_DIR/ramboot-state" ]]; then
                source "$STATE_DIR/ramboot-state"
                if [[ "$POWOS_SKIP_CUSTOM" == "1" ]] || [[ "$POWOS_SKIP_UPDATES" == "1" ]]; then
                    echo -e "${YELLOW}Currently running with rollback:${NC}"
                    [[ "$POWOS_SKIP_CUSTOM" == "1" ]] && echo "  - Custom layer skipped"
                    [[ "$POWOS_SKIP_UPDATES" == "1" ]] && echo "  - Updates layer skipped"
                fi
            fi
            ;;

        custom)
            echo "Setting rollback: skip custom layer on next boot"
            mkdir -p "$(dirname "$KARGS_FILE")"
            echo "rd.powos.skip.custom=1" >> "$KARGS_FILE"
            echo "  (informational record written to $KARGS_FILE — nothing reads it at boot)"

            _rollback_apply_kargs add "rd.powos.skip.custom=1" || exit 1

            echo -e "${GREEN}✓ Custom layer will be skipped on next boot${NC}"
            echo "  Your customizations won't load - only base + updates"
            echo "  Run 'powos rollback reset' to undo"
            ;;

        updates)
            echo "Setting rollback: skip updates layer on next boot"
            mkdir -p "$(dirname "$KARGS_FILE")"
            echo "rd.powos.skip.updates=1" >> "$KARGS_FILE"
            echo "  (informational record written to $KARGS_FILE — nothing reads it at boot)"

            _rollback_apply_kargs add "rd.powos.skip.updates=1" || exit 1

            echo -e "${GREEN}✓ Updates layer will be skipped on next boot${NC}"
            echo "  System updates won't load - only base + custom"
            echo "  Run 'powos rollback reset' to undo"
            ;;

        all)
            echo "Setting rollback: boot with base only"
            mkdir -p "$(dirname "$KARGS_FILE")"
            echo "rd.powos.skip.custom=1" > "$KARGS_FILE"
            echo "rd.powos.skip.updates=1" >> "$KARGS_FILE"
            echo "  (informational record written to $KARGS_FILE — nothing reads it at boot)"

            _rollback_apply_kargs add "rd.powos.skip.custom=1 rd.powos.skip.updates=1" || exit 1

            echo -e "${GREEN}✓ Will boot with base layer only${NC}"
            echo "  No customizations or updates will load"
            echo "  Run 'powos rollback reset' to undo"
            ;;

        reset)
            echo "Clearing rollback flags..."
            rm -f "$KARGS_FILE"

            _rollback_apply_kargs remove "rd.powos.skip.custom rd.powos.skip.updates" || exit 1

            echo -e "${GREEN}✓ Rollback flags cleared${NC}"
            echo "  All layers will load on next boot"
            ;;

        *)
            echo "Unknown rollback target: $target"
            echo "Valid options: custom, updates, all, reset"
            exit 1
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Update Command
# ═══════════════════════════════════════════════════════════════════

cmd_update() {
    local action="${1:-check}"
    local UPDATES_LAYER="/run/powos/usb-layers/layers/updates"

    case "$action" in
        check)
            echo -e "${BOLD}${CYAN}Checking for Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Check bootc for base OS updates
            echo "Base OS (via bootc):"
            if command -v bootc &>/dev/null; then
                if bootc upgrade --check 2>/dev/null; then
                    echo "  Run 'powos update os' to apply"
                else
                    echo "  System is up to date (or offline)"
                fi
            else
                echo "  bootc not available"
            fi
            echo ""

            # Check for package updates
            echo "Packages:"
            if [[ -f /run/ostree-booted ]]; then
                # Atomic host: packages ride the base image (dnf is a guard
                # stub here — piping it into wc used to produce a multi-line
                # value and an arithmetic-syntax error on this exact screen).
                echo "  Managed by the base image — 'powos upgrade' covers OS + packages"
            elif command -v dnf5 &>/dev/null; then
                local updates
                updates=$(dnf5 check-update --quiet 2>/dev/null | grep -Ec '^[[:alnum:]]') || true
                if [[ "${updates:-0}" -gt 0 ]]; then
                    echo "  $updates package updates available"
                    echo "  Run 'powos update packages' to install"
                else
                    echo "  System is up to date"
                fi
            else
                echo "  No supported package manager found"
            fi
            echo ""
            echo "Commands:"
            echo "  powos update os        - Apply OS updates (goes to updates layer)"
            echo "  powos update packages  - Apply package updates (goes to custom layer)"
            echo "  powos update apply     - Apply all updates"
            ;;

        os)
            echo -e "${BOLD}${CYAN}Applying OS Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Ensure USB is connected
            if [[ "$(get_usb_status)" != "connected" ]]; then
                echo -e "${RED}Error: USB not connected${NC}"
                echo "Updates need USB connected to persist to updates layer"
                exit 1
            fi

            # Verify the USB layers dir is a real mount before staging.
            # A bare mkdir here would fabricate a tmpfs directory and stage
            # "updates" into RAM while claiming success.
            if ! mountpoint -q /run/powos/usb-layers 2>/dev/null; then
                echo -e "${RED}Error: /run/powos/usb-layers is not a mountpoint${NC}"
                echo "The USB data partition is not bind-mounted — staging updates"
                echo "here would write to RAM and be lost on reboot."
                echo "Check 'powos status' and reconnect/remount the USB drive."
                exit 1
            fi

            # Create updates layer directory
            mkdir -p "$UPDATES_LAYER"

            if command -v bootc &>/dev/null; then
                echo "Fetching OS update via bootc..."
                echo "This updates the base OS image without affecting your customizations."
                echo ""

                # bootc upgrade will stage the update
                # On atomic systems, this prepares the update for next boot
                if bootc upgrade 2>&1; then
                    echo ""
                    echo -e "${GREEN}✓ OS update staged${NC}"
                    echo "  Update will be applied on next boot"
                    echo "  Your customizations remain in the custom layer"
                    echo ""
                    echo "  If the update causes issues, run:"
                    echo "    powos rollback updates"
                else
                    echo -e "${RED}OS update failed${NC}"
                    exit 1
                fi
            else
                echo -e "${YELLOW}bootc not available${NC}"
                echo "Falling back to dnf for system updates..."
                echo "These updates will go to the updates layer."
                echo ""

                # For non-bootc systems, use dnf but target updates layer
                # This requires mounting updates layer as writable
                if [[ -d "$UPDATES_LAYER" ]]; then
                    # Use dnf with installroot to put updates in the layer
                    echo "Installing system updates to updates layer..."
                    dnf upgrade -y --installroot="$UPDATES_LAYER" --releasever=/ 2>/dev/null || \
                        dnf upgrade -y  # Fallback to normal upgrade
                fi

                echo ""
                echo -e "${GREEN}✓ System updates applied${NC}"
            fi
            ;;

        packages)
            echo -e "${BOLD}${CYAN}Applying Package Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Ensure USB is connected for persistence
            if [[ "$(get_usb_status)" != "connected" ]]; then
                echo -e "${RED}Error: USB not connected${NC}"
                echo "Updates need USB connected to persist"
                exit 1
            fi

            # Apply package updates (goes to RAM, syncs to custom layer)
            if command -v dnf &>/dev/null; then
                echo "Installing package updates..."
                echo "These go to your custom layer (separate from OS updates)."
                echo ""
                dnf upgrade -y

                # Sync to custom layer
                echo ""
                echo "Syncing to custom layer..."
                if [[ -x "$LAYER_SYNC" ]]; then
                    python3 "$LAYER_SYNC" --sync-now
                fi
            fi

            echo ""
            echo -e "${GREEN}✓ Package updates applied${NC}"
            echo "  Changes synced to custom layer"
            echo "  Will persist across reboots"
            ;;

        apply)
            echo -e "${BOLD}${CYAN}Applying All Updates${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Ensure USB is connected for persistence
            if [[ "$(get_usb_status)" != "connected" ]]; then
                echo -e "${RED}Error: USB not connected${NC}"
                echo "Updates need USB connected to persist"
                exit 1
            fi

            # Apply OS updates first
            echo "=== OS Updates ==="
            if command -v bootc &>/dev/null; then
                bootc upgrade 2>&1 || echo "No OS updates or bootc failed"
            fi
            echo ""

            # Then package updates
            echo "=== Package Updates ==="
            if command -v dnf &>/dev/null; then
                dnf upgrade -y
            fi

            # Sync to custom layer
            echo ""
            echo "Syncing to custom layer..."
            if [[ -x "$LAYER_SYNC" ]]; then
                python3 "$LAYER_SYNC" --sync-now
            fi

            echo ""
            echo -e "${GREEN}✓ All updates applied${NC}"
            echo "  OS updates staged for next boot (updates layer)"
            echo "  Package updates synced to custom layer"
            ;;

        powos|self)
            echo -e "${BOLD}${CYAN}Updating PowOS${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Default source location (bundled with PowOS)
            local POWOS_SRC="${POWOS_SRC:-/var/lib/powos/src}"
            local custom_src=""

            # Parse --from argument
            shift
            while [[ $# -gt 0 ]]; do
                case "$1" in
                    --from)
                        custom_src="$2"
                        shift 2
                        ;;
                    --pull)
                        # SAFE pull: attach-in-place (bundled snapshot) or plain
                        # rebase (existing checkout) WITHOUT ever discarding local
                        # edits. Replaces the old `git checkout -f` that blindly
                        # reset to master and nuked uncommitted work. See lib/self.sh.
                        source "$POWOS_LIB/self.sh"
                        self_safe_pull "$POWOS_SRC" || return 1
                        shift
                        ;;
                    *)
                        shift
                        ;;
                esac
            done

            # Use custom source if specified
            [[ -n "$custom_src" ]] && POWOS_SRC="$custom_src"

            if [[ ! -d "$POWOS_SRC" ]]; then
                echo -e "${RED}PowOS source not found at: $POWOS_SRC${NC}"
                echo ""
                echo "Options:"
                echo "  1. Specify source location:"
                echo "     powos update self --from /mnt/disk/Projects/PowOS"
                echo ""
                echo "  2. The source should be bundled at /var/lib/powos/src"
                echo "     (included in PowOS ISO builds)"
                return 1
            fi

            echo "Source: $POWOS_SRC"

            # Show what's changed (if git available)
            if [[ -d "$POWOS_SRC/.git" ]]; then
                local changes
                changes=$(cd "$POWOS_SRC" && git status --porcelain 2>/dev/null | wc -l)
                local commit
                commit=$(cd "$POWOS_SRC" && git log -1 --format="%h %s" 2>/dev/null || echo "unknown")
                echo "Commit: $commit"
                [[ "$changes" -gt 0 ]] && echo "Uncommitted changes: $changes files"
            fi
            echo ""

            # Install scripts
            echo "Installing scripts..."

            # bin/ -> /usr/bin/
            if [[ -d "$POWOS_SRC/bin" ]]; then
                for script in "$POWOS_SRC/bin"/*; do
                    [[ -f "$script" ]] || continue
                    local name=$(basename "$script")
                    sudo cp "$script" "/usr/bin/$name"
                    sudo chmod +x "/usr/bin/$name"
                    echo "  /usr/bin/$name"
                done
            fi

            # lib/ -> /usr/lib/powos/
            if [[ -d "$POWOS_SRC/lib" ]]; then
                sudo mkdir -p /usr/lib/powos
                sudo cp -r "$POWOS_SRC/lib/"* /usr/lib/powos/
                sudo chmod +x /usr/lib/powos/*.sh 2>/dev/null || true
                sudo chmod +x /usr/lib/powos/**/*.sh 2>/dev/null || true
                sudo chmod +x /usr/lib/powos/**/*.py 2>/dev/null || true
                echo "  /usr/lib/powos/ (lib/*)"
            fi

            # config/ -> /etc/powos/
            if [[ -d "$POWOS_SRC/config" ]]; then
                sudo mkdir -p /etc/powos
                sudo cp -r "$POWOS_SRC/config/"* /etc/powos/
                echo "  /etc/powos/ (config/*)"
            fi

            # systemd/ -> /usr/lib/systemd/system/ and /usr/lib/powos/
            if [[ -d "$POWOS_SRC/systemd" ]]; then
                for file in "$POWOS_SRC/systemd"/*.service; do
                    [[ -f "$file" ]] || continue
                    sudo cp "$file" /usr/lib/systemd/system/
                done
                for file in "$POWOS_SRC/systemd"/powos-*; do
                    [[ -f "$file" ]] && [[ ! "$file" == *.service ]] || continue
                    sudo cp "$file" /usr/lib/powos/
                    sudo chmod +x "/usr/lib/powos/$(basename "$file")"
                done
                echo "  /usr/lib/systemd/system/ (services)"
                sudo systemctl daemon-reload 2>/dev/null || true
            fi

            # sources/ -> /var/lib/powos/sources/
            if [[ -d "$POWOS_SRC/sources" ]]; then
                sudo mkdir -p /var/lib/powos/sources
                sudo cp -r "$POWOS_SRC/sources/"* /var/lib/powos/sources/
                echo "  /var/lib/powos/sources/"
            fi

            echo ""
            echo -e "${GREEN}✓ PowOS updated from source${NC}"
            echo ""
            echo "Changes applied immediately. You may want to:"
            echo "  - Restart your shell for PATH changes"
            echo "  - Run 'powos dev build-all' to rebuild overlays"
            echo ""
            echo "Tip: Edit source at $POWOS_SRC, then run 'powos update self'"
            ;;

        overlays)
            echo -e "${BOLD}${CYAN}Rebuilding Overlays with Latest Upstream${NC}"
            echo "════════════════════════════════════════"
            echo ""

            if [[ ! -d "$PROJECTS_DIR" ]]; then
                echo "No projects directory found"
                return 0
            fi

            local updated=0
            for proj_dir in "$PROJECTS_DIR"/*/; do
                local name=$(basename "$proj_dir")
                local conf="$proj_dir/project.conf"

                [[ "$name" == "*" ]] && continue
                [[ ! -f "$conf" ]] && continue

                source "$conf"

                # Only update if it's a fork with upstream
                if [[ "${PROJECT_TYPE:-}" == "fork" ]] && [[ -n "${UPSTREAM_URL:-}" ]]; then
                    echo "Updating $name..."
                    if declare -f cmd_dev &>/dev/null; then
                        cmd_dev update "$name" 2>/dev/null || echo "  Failed to update $name"
                    fi
                    ((updated++)) || true
                fi
            done

            if [[ "$updated" -eq 0 ]]; then
                echo "No forked projects to update"
            else
                echo ""
                echo -e "${GREEN}✓ Updated $updated overlay(s)${NC}"
            fi
            ;;

        *)
            echo "Usage: powos update {check|os|powos|packages|overlays|apply}"
            echo ""
            echo "  check     - Check for available updates"
            echo "  os        - Update Bazzite base OS"
            echo "  powos     - Update PowOS scripts"
            echo "  packages  - Update installed packages"
            echo "  overlays  - Rebuild overlays with latest upstream"
            echo "  apply     - Apply all updates (os + packages)"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Flush Command (RAM → USB)
# ═══════════════════════════════════════════════════════════════════

cmd_flush() {
    echo "Flushing RAM changes to USB..."

    # Sync layer changes
    if [[ -x "$LAYER_SYNC" ]]; then
        python3 "$LAYER_SYNC" --sync-now
    fi

    # Sync CacheFS if active
    if [[ -f "$STATE_DIR/cachefs-status.json" ]]; then
        python3 /usr/lib/powos/cachefs/cachefs-sync.py --sync-now 2>/dev/null || true
    fi

    echo -e "${GREEN}✓ Flush complete${NC}"
}

# ═══════════════════════════════════════════════════════════════════
# Other Commands
# ═══════════════════════════════════════════════════════════════════

cmd_safe() {
    if is_safe_to_unplug; then
        echo -e "${GREEN}✓ Safe to unplug USB${NC}"
        exit 0
    else
        echo -e "${RED}✗ Not safe - unsynced changes pending${NC}"
        echo "  There are changes since the last successful sync"
        echo "  Run 'powos flush' (or 'powos sync') first"
        exit 1
    fi
}

# ═══════════════════════════════════════════════════════════════════
# Health Command - System health summary
# ═══════════════════════════════════════════════════════════════════

cmd_health() {
    local use_ai=false
    local ai_prompt=""

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ai|-a)
                use_ai=true
                shift
                ;;
            --help|-h)
                echo "Usage: powos health [options] [prompt]"
                echo ""
                echo "Show system health summary or talk to health AI agent."
                echo ""
                echo "Options:"
                echo "  --ai, -a     Talk to health AI agent"
                echo ""
                echo "Examples:"
                echo "  powos health                    # Show health summary"
                echo "  powos health --ai               # Interactive health agent"
                echo "  powos health --ai 'why is sync slow?'"
                return 0
                ;;
            *)
                ai_prompt="$*"
                break
                ;;
        esac
    done

    if [[ "$use_ai" == "true" ]]; then
        # Gather system context and pass to health agent
        local context
        context=$(get_health_context)

        if [[ -n "$ai_prompt" ]]; then
            # One-shot with context - prepend context to prompt
            ai_call --agent health "SYSTEM CONTEXT:
$context

USER QUESTION: $ai_prompt"
        else
            # Interactive mode with health agent - pass context via --context
            echo -e "${CYAN}Starting health agent...${NC}"
            ai_interactive --agent health --context "$context"
        fi
        return
    fi

    # Non-AI: Show health summary
    echo -e "${BOLD}${CYAN}PowOS Health Check${NC}"
    echo "════════════════════════════════════════"
    echo ""

    local issues=0
    local warnings=0
    local POWOS_ROOT="${POWOS_ROOT:-/var/lib/powos}"

    # --- Layers ---
    echo -e "${CYAN}Layers${NC}"
    local layers
    layers=$(get_active_layers)
    if [[ "$layers" != "none" ]] && [[ -n "$layers" ]]; then
        echo -e "  ${GREEN}✓${NC} Layer stack active: $layers"
    else
        echo -e "  ${YELLOW}○${NC} Standard boot (no layers)"
        ((warnings++)) || true
    fi

    # Check for rollback flags
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        if [[ "${POWOS_SKIP_CUSTOM:-}" == "1" ]]; then
            echo -e "  ${YELLOW}⚠${NC} Custom layer SKIPPED (rollback active)"
            ((warnings++)) || true
        fi
        if [[ "${POWOS_SKIP_UPDATES:-}" == "1" ]]; then
            echo -e "  ${YELLOW}⚠${NC} Updates layer SKIPPED (rollback active)"
            ((warnings++)) || true
        fi
    fi
    echo ""

    # --- RAM Overlay ---
    echo -e "${CYAN}RAM Overlay${NC}"
    if is_ramboot; then
        local ram_size
        ram_size=$(get_ramboot_info)
        echo -e "  ${GREEN}✓${NC} Running from RAM ($ram_size allocated)"

        if [[ -d /run/powos-overlay/upper ]]; then
            local upper_used upper_files
            upper_used=$(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo "unknown")
            upper_files=$(find /run/powos-overlay/upper -type f 2>/dev/null | wc -l || echo "0")
            echo "    Used: $upper_used ($upper_files files changed)"
        fi
    else
        echo -e "  ${YELLOW}○${NC} Not running from RAM overlay"
        ((warnings++)) || true
    fi
    echo ""

    # --- USB ---
    echo -e "${CYAN}USB Drive${NC}"
    local usb_status
    usb_status=$(get_usb_status)
    case "$usb_status" in
        connected)
            echo -e "  ${GREEN}✓${NC} Connected"
            ;;
        disconnected)
            echo -e "  ${YELLOW}○${NC} Disconnected (working from RAM)"
            ((warnings++)) || true
            ;;
        *)
            echo -e "  ${RED}?${NC} Unknown status"
            ((issues++)) || true
            ;;
    esac
    echo ""

    # --- RAM ↔ USB Sync ---
    echo -e "${CYAN}Sync (RAM ↔ USB)${NC}"
    # Check for lock file (interrupted sync)
    if [[ -f "/run/powos/sync.lock" ]]; then
        echo -e "  ${RED}✗${NC} Sync lock exists (interrupted?)"
        ((issues++)) || true
    else
        echo -e "  ${GREEN}✓${NC} No sync locks"
    fi

    # Check for conflicts (if USB connected)
    if [[ "$usb_status" == "connected" ]]; then
        if declare -f check_for_conflicts &>/dev/null; then
            local conflict_status
            conflict_status=$(check_for_conflicts 2>/dev/null || echo "conflict")
            if [[ "$conflict_status" == "conflict" ]]; then
                echo -e "  ${RED}✗${NC} CONFLICT - USB modified by another machine"
                echo "      Run: powos sync resolve"
                ((issues++)) || true
            else
                echo -e "  ${GREEN}✓${NC} No conflicts"
            fi
        fi
    fi

    # Layer sync daemon
    if pgrep -f "layer-sync" &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Layer sync daemon running"
    elif [[ -f "$STATE_DIR/layer-sync-status.json" ]]; then
        echo -e "  ${YELLOW}○${NC} Layer sync not running (status file exists)"
    fi

    # Last sync time
    if [[ -f "$STATE_DIR/layer-sync-status.json" ]]; then
        local last_sync
        last_sync=$(python3 -c "
import json, time
try:
    s = json.load(open('$STATE_DIR/layer-sync-status.json'))
    t = s.get('last_sync', 0)
    if t > 0:
        delta = int(time.time() - t)
        if delta < 60: print(f'{delta}s ago')
        elif delta < 3600: print(f'{delta // 60}m ago')
        else: print(f'{delta // 3600}h ago')
    else: print('Never')
except: print('Unknown')
" 2>/dev/null || echo "Unknown")
        echo "    Last sync: $last_sync"
    fi
    echo ""

    # --- Cloud Backup ---
    echo -e "${CYAN}Backup (USB → Cloud)${NC}"
    local git_dir="$POWOS_ROOT/git"
    if [[ -d "$git_dir/.git" ]]; then
        echo -e "  ${GREEN}✓${NC} Git repo initialized"

        # Check if remote configured
        if git -C "$git_dir" remote get-url origin &>/dev/null; then
            local remote_url
            remote_url=$(git -C "$git_dir" remote get-url origin 2>/dev/null | sed 's/.*[:/]\([^/]*\/[^/]*\)\.git/\1/' | head -c 30)
            echo "    Remote: $remote_url"

            # Check ahead/behind
            git -C "$git_dir" fetch origin --quiet 2>/dev/null || true
            local ahead behind
            ahead=$(git -C "$git_dir" rev-list --count origin/HEAD..HEAD 2>/dev/null || echo "?")
            behind=$(git -C "$git_dir" rev-list --count HEAD..origin/HEAD 2>/dev/null || echo "?")
            if [[ "$ahead" != "?" ]] && [[ "$behind" != "?" ]]; then
                if [[ "$ahead" -gt 0 ]] && [[ "$behind" -gt 0 ]]; then
                    echo -e "    ${YELLOW}⚠${NC} Diverged: $ahead ahead, $behind behind"
                    ((warnings++)) || true
                elif [[ "$ahead" -gt 0 ]]; then
                    echo -e "    ${YELLOW}○${NC} $ahead commits to push"
                elif [[ "$behind" -gt 0 ]]; then
                    echo -e "    ${YELLOW}○${NC} $behind commits to pull"
                else
                    echo -e "    ${GREEN}✓${NC} Up to date"
                fi
            fi
        else
            echo -e "  ${YELLOW}○${NC} No remote configured"
            echo "      Run: powos backup setup <url>"
        fi

        # Check for uncommitted changes
        local uncommitted
        uncommitted=$(git -C "$git_dir" status --porcelain 2>/dev/null | wc -l || echo "0")
        if [[ "$uncommitted" -gt 0 ]]; then
            echo "    Uncommitted: $uncommitted files"
        fi
    else
        echo -e "  ${YELLOW}○${NC} Not initialized"
        echo "      Run: powos backup setup <url>"
    fi
    echo ""

    # --- User Data (CacheFS) ---
    echo -e "${CYAN}User Data (CacheFS)${NC}"
    if is_cachefs_active; then
        echo -e "  ${GREEN}✓${NC} CacheFS active"
        if pgrep -f "cachefs" &>/dev/null; then
            echo -e "  ${GREEN}✓${NC} CacheFS daemon running"
        fi
        if [[ -f "$STATE_DIR/cachefs-status.json" ]]; then
            python3 -c "
import json
try:
    s = json.load(open('$STATE_DIR/cachefs-status.json'))
    print(f\"    Cached: {s.get('cached_files', 0)} files\")
    pending = s.get('pending_changes', 0)
    if pending > 0:
        print(f\"    Pending writes: {pending}\")
except: pass
" 2>/dev/null || true
        fi
    else
        echo -e "  ${YELLOW}○${NC} CacheFS not active"
    fi
    echo ""

    # --- Projects ---
    echo -e "${CYAN}Projects${NC}"
    local projects_dir="$POWOS_ROOT/projects"
    if [[ -d "$projects_dir" ]]; then
        local project_count enabled_count
        project_count=$(find "$projects_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l || echo "0")

        if [[ "$project_count" -gt 0 ]]; then
            echo "    Total: $project_count"

            # Count enabled (those with extensions)
            enabled_count=0
            for proj in "$projects_dir"/*/; do
                local name=$(basename "$proj")
                [[ "$name" == "*" ]] && continue
                if [[ -d "$POWOS_ROOT/extensions/$name" ]] || [[ -L "/var/lib/extensions/$name" ]]; then
                    ((enabled_count++)) || true
                fi
            done
            if [[ "$enabled_count" -gt 0 ]]; then
                echo "    Enabled: $enabled_count"
            fi
        else
            echo -e "  ${YELLOW}○${NC} No projects"
            echo "      Create with: powos dev new <name>"
        fi
    else
        echo -e "  ${YELLOW}○${NC} Projects dir not found"
    fi
    echo ""

    # --- Overlays/Extensions ---
    echo -e "${CYAN}Overlays${NC}"
    local extensions_dir="$POWOS_ROOT/extensions"
    local system_ext_dir="/var/lib/extensions"
    if [[ -d "$extensions_dir" ]]; then
        local built_count enabled_count
        built_count=$(find "$extensions_dir" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l || echo "0")

        if [[ "$built_count" -gt 0 ]]; then
            echo "    Built: $built_count"

            # Count enabled
            enabled_count=0
            if [[ -d "$system_ext_dir" ]]; then
                enabled_count=$(find "$system_ext_dir" -maxdepth 1 -type l 2>/dev/null | wc -l || echo "0")
            fi
            if [[ "$enabled_count" -gt 0 ]]; then
                echo "    Enabled: $enabled_count"
            fi
        else
            echo -e "  ${YELLOW}○${NC} No overlays built"
        fi
    else
        echo -e "  ${YELLOW}○${NC} Extensions dir not found"
    fi

    # Check systemd-sysext status
    if command -v systemd-sysext &>/dev/null; then
        local sysext_status
        # grep -c always prints a count (0 for no matches) but exits 1 when
        # count is 0. The old `|| echo "0"` then APPENDED a second "0" and
        # the arithmetic `[[ $var -gt 0 ]]` blew up on the two-line value.
        sysext_status=$(systemd-sysext status 2>/dev/null | grep -c "active" || true)
        if [[ "$sysext_status" -gt 0 ]]; then
            echo "    systemd-sysext: $sysext_status active"
        fi
    fi
    echo ""

    # --- Containers ---
    echo -e "${CYAN}Containers${NC}"
    if command -v distrobox &>/dev/null; then
        local distrobox_count
        distrobox_count=$(distrobox list --no-color 2>/dev/null | grep -c "Up\|Created" || echo "0")
        echo "    Distrobox: $distrobox_count"
    fi

    if command -v podman &>/dev/null; then
        local container_count image_count
        container_count=$(podman ps -q 2>/dev/null | wc -l || echo "0")
        image_count=$(podman images -q 2>/dev/null | wc -l || echo "0")
        echo "    Podman running: $container_count"
        echo "    Images: $image_count"
    else
        echo -e "  ${YELLOW}○${NC} Podman not available"
    fi
    echo ""

    # --- AI System ---
    echo -e "${CYAN}AI System${NC}"
    local ai_available=false

    # Check for AI clients
    if command -v claude &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Claude CLI available"
        ai_available=true
    fi
    if command -v gemini &>/dev/null; then
        echo -e "  ${GREEN}✓${NC} Gemini CLI available"
        ai_available=true
    fi
    if command -v ollama &>/dev/null; then
        if ollama list &>/dev/null 2>&1; then
            local model_count
            model_count=$(ollama list 2>/dev/null | tail -n +2 | wc -l || echo "0")
            echo -e "  ${GREEN}✓${NC} Ollama available ($model_count models)"
            ai_available=true
        else
            echo -e "  ${YELLOW}○${NC} Ollama installed but not running"
        fi
    fi

    if [[ "$ai_available" == "false" ]]; then
        echo -e "  ${YELLOW}○${NC} No AI clients found"
        echo "      Install: claude, gemini, or ollama"
    fi

    # Check agent configs
    local agents_dir="$POWOS_ROOT/../config/ai/agents"
    [[ ! -d "$agents_dir" ]] && agents_dir="/etc/powos/ai/agents"
    [[ ! -d "$agents_dir" ]] && agents_dir="$(dirname "$0")/../config/ai/agents"
    if [[ -d "$agents_dir" ]]; then
        local agent_count
        agent_count=$(find "$agents_dir" -name "*.conf" 2>/dev/null | wc -l || echo "0")
        if [[ "$agent_count" -gt 0 ]]; then
            echo "    Agents configured: $agent_count"
        fi
    fi
    echo ""

    # --- Hardware Profile ---
    echo -e "${CYAN}Hardware${NC}"
    if [[ -f "$STATE_DIR/hardware" ]]; then
        source "$STATE_DIR/hardware" 2>/dev/null || true
        echo "    Profile: ${ACTIVE_PROFILE:-unknown}"
        echo "    GPU: ${GPU_TYPE:-unknown}"
        echo "    Power: ${POWER_SOURCE:-unknown}"
    else
        echo -e "  ${YELLOW}○${NC} Hardware not detected"
    fi
    echo ""

    # --- Summary ---
    echo "════════════════════════════════════════"
    if [[ $issues -gt 0 ]]; then
        echo -e "${RED}Issues: $issues${NC}  ${YELLOW}Warnings: $warnings${NC}"
        echo ""
        echo "Run 'powos health --ai' to troubleshoot."
    elif [[ $warnings -gt 0 ]]; then
        echo -e "${GREEN}No issues${NC}  ${YELLOW}Warnings: $warnings${NC}"
    else
        echo -e "${GREEN}✓ All systems healthy${NC}"
    fi
}

# Get system context for AI health agent
get_health_context() {
    local ctx=""

    ctx+="=== PowOS System Context ===\n\n"

    # Layers
    ctx+="LAYERS:\n"
    ctx+="  Active: $(get_active_layers)\n"
    ctx+="  RAM boot: $(is_ramboot && echo 'yes' || echo 'no')\n"
    if [[ -f "$STATE_DIR/ramboot-state" ]]; then
        source "$STATE_DIR/ramboot-state"
        ctx+="  RAM size: ${POWOS_RAM_SIZE:-unknown}\n"
        ctx+="  Skip custom: ${POWOS_SKIP_CUSTOM:-0}\n"
        ctx+="  Skip updates: ${POWOS_SKIP_UPDATES:-0}\n"
    fi
    ctx+="\n"

    # USB
    ctx+="USB:\n"
    ctx+="  Status: $(get_usb_status)\n"
    ctx+="\n"

    # Sync
    ctx+="SYNC:\n"
    ctx+="  Lock file: $(test -f /run/powos/sync.lock && echo 'EXISTS (possible interrupted sync)' || echo 'none')\n"
    if declare -f check_for_conflicts &>/dev/null; then
        ctx+="  Conflicts: $(check_for_conflicts 2>/dev/null || echo 'DETECTED')\n"
    fi
    if declare -f read_sync_marker &>/dev/null; then
        ctx+="  Last sync by: $(read_sync_marker 2>/dev/null || echo 'unknown')\n"
    fi
    ctx+="\n"

    # RAM usage
    ctx+="RAM OVERLAY:\n"
    if [[ -d /run/powos-overlay/upper ]]; then
        ctx+="  Files changed: $(find /run/powos-overlay/upper -type f 2>/dev/null | wc -l)\n"
        ctx+="  Size: $(du -sh /run/powos-overlay/upper 2>/dev/null | cut -f1 || echo 'unknown')\n"
    fi
    ctx+="\n"

    # Recent changes (process substitution — a `| while read` pipeline runs
    # in a subshell and its ctx+= updates would be lost)
    ctx+="RECENT CHANGES (last 10 in RAM):\n"
    if [[ -d /run/powos-overlay/upper ]]; then
        local f
        while IFS= read -r f; do
            ctx+="  $f\n"
        done < <(find /run/powos-overlay/upper -type f -mmin -60 2>/dev/null | head -10)
    fi
    ctx+="\n"

    echo -e "$ctx"
}

cmd_hardware() {
    if [[ -f "$STATE_DIR/hardware" ]]; then
        cat "$STATE_DIR/hardware"
    else
        echo "Hardware not detected yet"
    fi
}

cmd_version() {
    echo "PowOS version $VERSION"
    # The commit the running image was built from. Lives under /usr/lib/powos
    # (part of the read-only OS image) so it always reflects the CURRENTLY
    # booted image after a bootc upgrade/switch — /var was a bootc trap since
    # it only gets seeded on the initial stateroot deploy.
    local marker="/usr/lib/powos/.powos-src-commit"
    [[ -r "$marker" ]] || marker="/var/lib/powos/.powos-src-commit"  # legacy fallback
    if [[ -r "$marker" ]]; then
        local sha; sha="$(tr -d '[:space:]' < "$marker" 2>/dev/null)"
        [[ -n "$sha" ]] && echo "Source commit: $sha"
    fi
    if is_ramboot; then
        echo "Layers: $(get_active_layers)"
    fi
}

# ═══════════════════════════════════════════════════════════════════
# Install Command - Unified package installation
# ═══════════════════════════════════════════════════════════════════

cmd_install() {
    local target=""
    local packages=()
    local export_gui=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --container|-c)
                target="$2"
                shift 2
                ;;
            --export|-e)
                export_gui=true
                shift
                ;;
            --host)
                # Explicit host install (rpm-ostree layer) — the default path
                # when no container is given; flag exists so the install router
                # can force it unambiguously.
                shift
                ;;
            --help|-h)
                echo "Usage: powos install [options] <packages...>"
                echo ""
                echo "Install packages to the host OS or a container."
                echo ""
                echo "Options:"
                echo "  --container, -c NAME   Install to a distrobox container"
                echo "  --export, -e           Export GUI apps to host menu (with -c)"
                echo ""
                echo "Examples:"
                echo "  powos install neovim htop        # Install to host (custom layer)"
                echo "  powos install -c dev nodejs      # Install nodejs in 'dev' container"
                echo "  powos install -c dev -e code     # Install VSCode in container, export to host"
                echo "  powos install -c arch -e firefox # Install Firefox in Arch, use on host"
                return 0
                ;;
            *)
                packages+=("$1")
                shift
                ;;
        esac
    done

    if [[ ${#packages[@]} -eq 0 ]]; then
        echo "Error: No packages specified"
        echo "Run 'powos install --help' for usage"
        return 1
    fi

    if [[ -n "$target" ]]; then
        # Install to container
        echo -e "${CYAN}Installing to container '$target':${NC} ${packages[*]}"

        # Check if container exists (exact name match on the NAME column —
        # a prefix grep would let 'dev' match 'dev-old')
        if ! distrobox list --no-color 2>/dev/null | \
             awk -F'|' -v n="$target" 'NR>1 { name=$2; gsub(/^[ \t]+|[ \t]+$/, "", name); if (name == n) found=1 } END { exit(found ? 0 : 1) }'; then
            echo -e "${YELLOW}Container '$target' doesn't exist. Create it first:${NC}"
            echo "  powos containers create $target"
            return 1
        fi

        # Run install inside container. Packages are passed as arguments —
        # splicing them into the command string would allow shell injection
        # and break on names with special characters.
        distrobox enter "$target" -- bash -c '
            if command -v apt &>/dev/null; then
                sudo apt update && sudo apt install -y "$@"
            elif command -v dnf &>/dev/null; then
                sudo dnf install -y "$@"
            elif command -v pacman &>/dev/null; then
                sudo pacman -Syu --noconfirm "$@"
            elif command -v apk &>/dev/null; then
                sudo apk add "$@"
            else
                echo "Unknown package manager"
                exit 1
            fi
        ' _ "${packages[@]}"

        if [[ "$export_gui" == "true" ]]; then
            echo ""
            echo -e "${CYAN}Exporting GUI apps to host menu...${NC}"
            for pkg in "${packages[@]}"; do
                # Try to export the app (may fail if not a GUI app, that's ok)
                distrobox-export --app "$pkg" 2>/dev/null && \
                    echo -e "  ${GREEN}✓${NC} Exported: $pkg" || \
                    echo -e "  ${YELLOW}○${NC} Not a GUI app: $pkg"
            done
        fi

        echo ""
        echo -e "${GREEN}✓ Installed to container '$target'${NC}"
        if [[ "$export_gui" == "true" ]]; then
            echo "  GUI apps are now in your application menu!"
        else
            echo "  Enter with: powos containers enter $target"
        fi
    else
        # Install to host.
        echo -e "${CYAN}Installing to host:${NC} ${packages[*]}"

        if [[ -f /run/ostree-booted ]] && command -v rpm-ostree &>/dev/null; then
            # Atomic/composefs host (Bazzite/bootc): /usr is a read-only image
            # and `dnf` is a guard stub that just errors. Layer via rpm-ostree —
            # packages persist across base updates and roll back cleanly. Try to
            # apply them live so no reboot is needed; otherwise they activate on
            # the next boot.
            echo -e "  ${YELLOW}atomic host — layering via rpm-ostree${NC}"
            if ! sudo rpm-ostree install --idempotent --allow-inactive "${packages[@]}"; then
                echo -e "${RED}✗ rpm-ostree install failed${NC}"
                return 1
            fi
            echo ""
            echo -e "${GREEN}✓ Layered: ${packages[*]}${NC}"
            if sudo rpm-ostree apply-live --allow-replacement 2>/dev/null; then
                echo -e "  ${GREEN}Applied live — available now, no reboot.${NC}"
            else
                echo -e "  Staged; activate with:  ${CYAN}systemctl reboot${NC}"
            fi
            return 0
        fi

        # Non-atomic hosts (traditional distros). Use the real dnf5 binary, not
        # the atomic `dnf` guard wrapper.
        if command -v dnf5 &>/dev/null; then
            sudo dnf5 install -y "${packages[@]}"
        elif command -v apt &>/dev/null; then
            sudo apt update && sudo apt install -y "${packages[@]}"
        elif command -v pacman &>/dev/null; then
            sudo pacman -Syu --noconfirm "${packages[@]}"
        else
            echo "No supported host package manager found"
            return 1
        fi

        # Layer-sync only applies on the writable-overlay (USB) variant, where
        # /usr is a RAM overlay. On composefs bootc hosts rpm-ostree owns
        # persistence (handled above), so this is skipped there.
        if is_ramboot && [[ -w /usr ]] && [[ -x "$LAYER_SYNC" ]]; then
            echo "Syncing to custom layer..."
            if python3 "$LAYER_SYNC" --sync-now; then
                echo ""
                echo -e "${GREEN}✓ Installed to host${NC}"
                echo "  Changes synced to custom layer and will persist"
            else
                echo ""
                echo -e "${YELLOW}⚠ Installed to host, but layer sync FAILED${NC}"
                echo "  Persistence is NOT confirmed — changes may be lost on reboot"
                echo "  Retry with: powos layers sync"
            fi
        else
            echo ""
            echo -e "${GREEN}✓ Installed to host${NC}"
            echo "  Changes will persist in custom layer"
        fi
    fi
}

# ═══════════════════════════════════════════════════════════════════
# Build Command - Build containers from Dockerfile/Containerfile
# ═══════════════════════════════════════════════════════════════════

cmd_build() {
    local subcmd="${1:-}"

    # Handle subcommands
    case "$subcmd" in
        iso)
            shift
            cmd_build_iso "$@"
            return
            ;;
        test)
            shift
            cmd_build_iso --test "$@"
            return
            ;;
        image)
            shift
            source "$POWOS_LIB/build-image.sh"
            cmd_build_image "$@"
            return
            ;;
    esac

    local context="${1:-.}"
    local tag="${2:-}"
    local dockerfile=""

    # Find Dockerfile or Containerfile
    if [[ -f "$context/Containerfile" ]]; then
        dockerfile="$context/Containerfile"
    elif [[ -f "$context/Dockerfile" ]]; then
        dockerfile="$context/Dockerfile"
    elif [[ -f "$context" ]]; then
        dockerfile="$context"
        context=$(dirname "$dockerfile")
    else
        echo "Usage: powos build [context] [tag]"
        echo ""
        echo "Build a container image from Dockerfile or Containerfile."
        echo ""
        echo "Examples:"
        echo "  powos build                        # Build from ./Containerfile or ./Dockerfile"
        echo "  powos build . myapp:latest         # Build with tag"
        echo "  powos build ./path/to/project      # Build from specific directory"
        echo ""
        echo "Note: Podman reads Dockerfiles natively - no conversion needed!"
        return 1
    fi

    echo -e "${CYAN}Building from:${NC} $dockerfile"
    [[ -n "$tag" ]] && echo -e "${CYAN}Tag:${NC} $tag"
    echo ""

    local cmd="podman build"
    [[ -n "$tag" ]] && cmd="$cmd -t $tag"
    cmd="$cmd -f $dockerfile $context"

    echo -e "${YELLOW}Running:${NC} $cmd"
    echo ""

    eval "$cmd"
    local result=$?

    if [[ $result -eq 0 ]]; then
        echo ""
        echo -e "${GREEN}✓ Build successful${NC}"
        [[ -n "$tag" ]] && echo "  Run with: podman run $tag"
    else
        echo ""
        echo -e "${RED}✗ Build failed${NC}"
    fi

    return $result
}

# ═══════════════════════════════════════════════════════════════════
# Build ISO - Create bootable PowOS ISO
# ═══════════════════════════════════════════════════════════════════

cmd_build_iso() {
    local test_only=false
    [[ "${1:-}" == "--test" ]] && test_only=true

    echo -e "${BOLD}${CYAN}PowOS ISO Builder${NC}"
    echo "════════════════════════════════════════"
    echo ""

    local powos_src="${POWOS_SRC:-/var/lib/powos/src}"
    [[ ! -d "$powos_src" ]] && powos_src="$POWOS_ROOT"
    [[ ! -d "$powos_src" ]] && powos_src="."

    local output_dir="$powos_src/build/output"
    mkdir -p "$output_dir"

    # Detect if we're inside container or on host
    local in_container=false
    [[ -f /.dockerenv ]] || [[ -f /run/.containerenv ]] && in_container=true

    if $in_container; then
        # Inside container - check if Docker image exists, import to podman
        echo "Running inside container..."

        if ! command -v podman &>/dev/null; then
            echo -e "${RED}Error: podman not found${NC}"
            return 1
        fi

        # Check if image already in podman
        if podman image exists localhost/powos:latest 2>/dev/null; then
            echo -e "${GREEN}✓ Image already in podman cache${NC}"
        else
            echo "Building with podman..."
            if ! podman build -f "$powos_src/Containerfile" -t localhost/powos:latest "$powos_src"; then
                echo -e "${RED}Build failed${NC}"
                return 1
            fi
        fi

        if $test_only; then
            echo -e "${GREEN}✓ Test build complete${NC}"
            return 0
        fi

        # Build ISO
        echo -e "${CYAN}Building bootable ISO...${NC}"
        podman run --rm -it --privileged \
            --security-opt label=type:unconfined_t \
            -v "$output_dir:/output" \
            -v /var/lib/containers/storage:/var/lib/containers/storage \
            quay.io/centos-bootc/bootc-image-builder:latest \
            --type iso --rootfs btrfs --local \
            localhost/powos:latest
    else
        # On host - use docker compose (cached!)
        echo "Source: $powos_src"
        echo ""

        if command -v docker &>/dev/null; then
            echo -e "${CYAN}Step 1: Building with Docker (using cache)...${NC}"
            if docker compose -f "$powos_src/docker-compose.yml" build; then
                echo -e "${GREEN}✓ Container image built${NC}"
            else
                echo -e "${RED}Build failed${NC}"
                return 1
            fi

            if $test_only; then
                echo ""
                echo -e "${GREEN}✓ Test build complete${NC}"
                echo "Run with: docker compose up"
                return 0
            fi

            # For full ISO, run inside container with podman
            echo ""
            echo -e "${CYAN}Step 2: Building ISO inside container...${NC}"
            docker compose run --rm --entrypoint bash powos -c "powos build iso"
        else
            echo -e "${RED}Error: docker not found${NC}"
            return 1
        fi
    fi

    # Check for ISO output
    local iso_file
    iso_file=$(find "$output_dir" -name "*.iso" -type f 2>/dev/null | head -1)
    if [[ -n "$iso_file" ]]; then
        echo ""
        echo -e "${GREEN}╔════════════════════════════════════════╗${NC}"
        echo -e "${GREEN}║  PowOS ISO Ready!                      ║${NC}"
        echo -e "${GREEN}╚════════════════════════════════════════╝${NC}"
        echo ""
        echo "  ISO: $iso_file"
        echo "  Size: $(du -h "$iso_file" | cut -f1)"
        echo ""
        echo "  Write to USB:"
        echo "    sudo dd if=$iso_file of=/dev/sdX bs=4M status=progress"
    fi
}

# ═══════════════════════════════════════════════════════════════════
# Source Commands - Build custom versions of apps
# ═══════════════════════════════════════════════════════════════════

SOURCES_DIR="${POWOS_ROOT:-/var/lib/powos}/sources"
PROJECTS_DIR="${POWOS_ROOT:-/var/lib/powos}/projects"
EXTENSIONS_DIR="${POWOS_ROOT:-/var/lib/powos}/extensions"

# Source the unified dev system
if [[ -f /usr/lib/powos/dev-commands.sh ]]; then
    source /usr/lib/powos/dev-commands.sh
elif [[ -f "$(dirname "$0")/../lib/dev-commands.sh" ]]; then
    source "$(dirname "$0")/../lib/dev-commands.sh"
fi

# Source the AI agent system
if [[ -f /usr/lib/powos/ai/agent.sh ]]; then
    source /usr/lib/powos/ai/agent.sh
elif [[ -f "$(dirname "$0")/../lib/ai/agent.sh" ]]; then
    source "$(dirname "$0")/../lib/ai/agent.sh"
fi

# Source the RAM ↔ USB sync system
if [[ -f /usr/lib/powos/sync.sh ]]; then
    source /usr/lib/powos/sync.sh
elif [[ -f "$(dirname "$0")/../lib/sync.sh" ]]; then
    source "$(dirname "$0")/../lib/sync.sh"
fi

# Source the backup system (USB ↔ cloud)
if [[ -f /usr/lib/powos/backup.sh ]]; then
    source /usr/lib/powos/backup.sh
elif [[ -f "$(dirname "$0")/../lib/backup.sh" ]]; then
    source "$(dirname "$0")/../lib/backup.sh"
fi

# Legacy source command (kept for backward compatibility)
cmd_source() {
    local action="${1:-list}"

    case "$action" in
        list|ls)
            echo -e "${BOLD}${CYAN}Available Sources${NC}"
            echo "════════════════════════════════════════"
            echo ""

            if [[ ! -d "$SOURCES_DIR" ]]; then
                echo "No sources directory found"
                return 1
            fi

            for src in "$SOURCES_DIR"/*/; do
                local name=$(basename "$src")
                [[ "$name" == "*" ]] && continue

                local conf="$src/source.conf"
                local desc="Custom overlay"
                local upstream=""

                if [[ -f "$conf" ]]; then
                    source "$conf" 2>/dev/null || true
                    desc="${DESCRIPTION:-$desc}"
                    upstream="${UPSTREAM_URL:-}"
                fi

                # Check if built
                local status="${YELLOW}○${NC}"
                if [[ -d "$EXTENSIONS_DIR/$name" ]]; then
                    status="${GREEN}●${NC}"
                fi

                echo -e "  $status $name"
                echo "      $desc"
                [[ -n "$upstream" ]] && echo "      Source: $upstream"
            done
            echo ""
            echo "Legend: ${GREEN}●${NC} built  ${YELLOW}○${NC} not built"
            ;;

        get)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source get <name>"
                echo "       powos source get kde           # Fetch all KDE apps"
                echo "       powos source get kde:dolphin   # Fetch just Dolphin"
                echo ""
                echo "Fetch upstream source code for an app."
                echo "Run 'powos source list' to see available sources."
                return 1
            fi

            # Handle kde:app syntax
            local base_name="${name%%:*}"
            local app_name="${name#*:}"
            [[ "$base_name" == "$app_name" ]] && app_name=""

            local src_dir="$SOURCES_DIR/$base_name"
            local conf="$src_dir/source.conf"

            if [[ ! -f "$conf" ]]; then
                echo -e "${RED}No source.conf for '$base_name'${NC}"
                echo "Create one at: $conf"
                return 1
            fi

            # Special handling for kde - use fetch.sh
            if [[ "$base_name" == "kde" ]] && [[ -x "$src_dir/fetch.sh" ]]; then
                echo -e "${CYAN}Fetching KDE sources...${NC}"
                if [[ -n "$app_name" ]]; then
                    bash "$src_dir/fetch.sh" "$app_name"
                else
                    bash "$src_dir/fetch.sh"
                fi
                return $?
            fi

            source "$conf"

            if [[ -z "${UPSTREAM_URL:-}" ]]; then
                echo -e "${RED}No UPSTREAM_URL defined in source.conf${NC}"
                return 1
            fi

            local src_code_dir="$src_dir/upstream"
            echo -e "${CYAN}Fetching source for $name...${NC}"
            echo "  URL: $UPSTREAM_URL"
            echo "  Dir: $src_code_dir"
            echo ""

            mkdir -p "$src_code_dir"

            if [[ "$UPSTREAM_URL" == *.git ]] || [[ "$UPSTREAM_URL" == *github.com* ]] || [[ "$UPSTREAM_URL" == *gitlab.com* ]]; then
                # Git repo
                if [[ -d "$src_code_dir/.git" ]]; then
                    echo "Updating existing clone..."
                    cd "$src_code_dir" && git pull
                else
                    rm -rf "$src_code_dir"
                    git clone --depth 1 ${UPSTREAM_BRANCH:+--branch "$UPSTREAM_BRANCH"} "$UPSTREAM_URL" "$src_code_dir"
                fi
            elif [[ "$UPSTREAM_URL" == *.tar.* ]]; then
                # Tarball
                local tarball="$src_dir/$(basename "$UPSTREAM_URL")"
                curl -L -o "$tarball" "$UPSTREAM_URL"
                tar -xf "$tarball" -C "$src_code_dir" --strip-components=1
                rm "$tarball"
            else
                echo -e "${RED}Unknown source type${NC}"
                return 1
            fi

            echo ""
            echo -e "${GREEN}✓ Source fetched${NC}"
            echo "  Location: $src_code_dir"
            echo "  Next: powos source patch $name  (apply patches)"
            echo "        powos source build $name  (build overlay)"
            ;;

        patch)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source patch <name>"
                return 1
            fi

            local src_dir="$SOURCES_DIR/$name"
            local patches_dir="$src_dir/patches"
            local upstream_dir="$src_dir/upstream"

            if [[ ! -d "$upstream_dir" ]]; then
                echo -e "${RED}No upstream source. Run 'powos source get $name' first.${NC}"
                return 1
            fi

            if [[ ! -d "$patches_dir" ]] || [[ -z "$(ls -A "$patches_dir" 2>/dev/null)" ]]; then
                echo "No patches to apply for $name"
                return 0
            fi

            echo -e "${CYAN}Applying patches to $name...${NC}"
            cd "$upstream_dir"

            for patch in "$patches_dir"/*.patch; do
                [[ -f "$patch" ]] || continue
                echo "  Applying: $(basename "$patch")"
                git apply "$patch" 2>/dev/null || patch -p1 < "$patch"
            done

            echo ""
            echo -e "${GREEN}✓ Patches applied${NC}"
            ;;

        build)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source build <name>"
                echo "       powos source build kde:dolphin   # Build Dolphin from KDE"
                echo ""
                echo "Build an overlay from source."
                echo "The built overlay will override the system version."
                return 1
            fi

            # Handle kde:app syntax
            local base_name="${name%%:*}"
            local app_name="${name#*:}"
            [[ "$base_name" == "$app_name" ]] && app_name=""

            local src_dir="$SOURCES_DIR/$base_name"
            local build_script="$src_dir/build.sh"
            local source_conf="$src_dir/source.conf"

            if [[ ! -f "$build_script" ]]; then
                echo -e "${RED}No build.sh for '$base_name'${NC}"
                return 1
            fi

            echo -e "${CYAN}Building $name overlay...${NC}"

            # Install build dependencies if source.conf exists
            if [[ -f "$source_conf" ]]; then
                source "$source_conf"
                if [[ -n "${BUILD_DEPS:-}" ]]; then
                    echo -e "${CYAN}Installing build dependencies...${NC}"
                    if command -v dnf &>/dev/null; then
                        sudo dnf install -y --skip-unavailable $BUILD_DEPS
                    elif command -v apt-get &>/dev/null; then
                        sudo apt-get install -y $BUILD_DEPS
                    elif command -v pacman &>/dev/null; then
                        sudo pacman -S --noconfirm --needed $BUILD_DEPS
                    fi
                    echo ""
                fi
            fi

            # Set up output directory (use app name for kde:app)
            local overlay_name="${app_name:-$base_name}"
            local output_dir="$EXTENSIONS_DIR/$overlay_name"
            mkdir -p "$output_dir/usr/bin" "$output_dir/usr/lib"

            export OVERLAY_OUTPUT_DIR="$output_dir"
            export OVERLAY_NAME="$name"

            # Run build script
            bash "$build_script" "$output_dir"

            # Create extension-release file for systemd-sysext
            local release_dir="$output_dir/usr/lib/extension-release.d"
            mkdir -p "$release_dir"
            echo "ID=fedora" > "$release_dir/extension-release.$overlay_name"

            echo ""
            echo -e "${GREEN}✓ Overlay built${NC}"
            echo "  Location: $output_dir"
            echo ""
            echo "Enable with: powos source enable $overlay_name"
            ;;

        enable)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source enable <name>"
                return 1
            fi

            local ext_dir="$EXTENSIONS_DIR/$name"
            if [[ ! -d "$ext_dir" ]]; then
                echo -e "${RED}Overlay '$name' not built. Run 'powos source build $name' first.${NC}"
                return 1
            fi

            echo -e "${CYAN}Enabling $name overlay...${NC}"

            # Link to system extensions dir
            sudo ln -sf "$ext_dir" "/var/lib/extensions/$name" 2>/dev/null || \
                ln -sf "$ext_dir" "/var/lib/extensions/$name"

            # Refresh sysext
            if command -v systemd-sysext &>/dev/null; then
                sudo systemd-sysext refresh 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Overlay enabled${NC}"
            echo "  Custom $name now overrides system version!"
            ;;

        disable)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source disable <name>"
                return 1
            fi

            echo -e "${CYAN}Disabling $name overlay...${NC}"

            sudo rm -f "/var/lib/extensions/$name" 2>/dev/null || \
                rm -f "/var/lib/extensions/$name"

            if command -v systemd-sysext &>/dev/null; then
                sudo systemd-sysext refresh 2>/dev/null || true
            fi

            echo -e "${GREEN}✓ Overlay disabled${NC}"
            echo "  System $name restored"
            ;;

        save)
            # Save local changes as patches (for backup/sharing)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos source save <name>"
                echo "       powos source save kde:dolphin"
                echo ""
                echo "Saves your local edits as patch files."
                echo "Useful for backup or sharing your modifications."
                return 1
            fi

            # Handle kde:app syntax
            local base_name="${name%%:*}"
            local app_name="${name#*:}"
            [[ "$base_name" == "$app_name" ]] && app_name=""

            local src_dir="$SOURCES_DIR/$base_name"

            if [[ -n "$app_name" ]]; then
                # KDE app
                local upstream_dir="$src_dir/upstream/$app_name"
                local patches_dir="$src_dir/patches/$app_name"
            else
                # Regular source
                local upstream_dir="$src_dir/upstream"
                local patches_dir="$src_dir/patches"
            fi

            if [[ ! -d "$upstream_dir" ]]; then
                echo -e "${RED}No source found at $upstream_dir${NC}"
                return 1
            fi

            cd "$upstream_dir"

            # Check for changes
            if [[ -z "$(git status --porcelain 2>/dev/null)" ]]; then
                echo "No local changes to save."
                return 0
            fi

            mkdir -p "$patches_dir"

            # Generate patch from uncommitted changes
            local timestamp=$(date +%Y%m%d-%H%M%S)
            local patch_file="$patches_dir/local-changes-$timestamp.patch"

            echo -e "${CYAN}Saving changes to patch...${NC}"
            git diff > "$patch_file"
            git diff --staged >> "$patch_file"

            # Show what was saved
            local lines=$(wc -l < "$patch_file")
            echo -e "${GREEN}✓ Changes saved${NC}"
            echo "  Patch: $patch_file"
            echo "  Lines: $lines"
            echo ""
            echo "Your edits are preserved. You can now:"
            echo "  - Reset source: cd $upstream_dir && git checkout ."
            echo "  - Patches auto-apply on fresh builds"
            ;;

        new)
            local name="${2:-}"
            local upstream="${3:-}"

            if [[ -z "$name" ]]; then
                echo "Usage: powos source new <name> [upstream-url]"
                echo ""
                echo "Create a new source overlay template."
                echo ""
                echo "Examples:"
                echo "  powos source new myapp"
                echo "  powos source new firefox https://github.com/nicotine-plus/nicotine-plus"
                return 1
            fi

            local src_dir="$SOURCES_DIR/$name"
            if [[ -d "$src_dir" ]]; then
                echo -e "${YELLOW}Source '$name' already exists${NC}"
                return 1
            fi

            echo -e "${CYAN}Creating source template: $name${NC}"

            mkdir -p "$src_dir/patches"

            # Create source.conf
            cat > "$src_dir/source.conf" << EOF
# Source configuration for $name
# Edit this file to configure how the source is fetched and built

# Description shown in 'powos source list'
DESCRIPTION="Custom build of $name"

# Upstream source (git URL or tarball URL)
UPSTREAM_URL="${upstream:-}"

# Git branch (optional, for git sources)
UPSTREAM_BRANCH=""

# Build dependencies (space-separated)
BUILD_DEPS=""

# Runtime dependencies (space-separated)
RUNTIME_DEPS=""
EOF

            # Create build.sh template
            cat > "$src_dir/build.sh" << 'EOF'
#!/usr/bin/env bash
# build.sh - Build script for this overlay
#
# This script builds the custom version and installs to the overlay.
#
# Environment:
#   OVERLAY_OUTPUT_DIR - Where to place built files
#   OVERLAY_NAME       - Name of this overlay

set -euo pipefail

OUTPUT_DIR="${1:-$OVERLAY_OUTPUT_DIR}"
NAME="${OVERLAY_NAME:-$(basename "$(dirname "$0")")}"
SRC_DIR="$(dirname "$0")"
UPSTREAM_DIR="$SRC_DIR/upstream"

echo "Building: $NAME"
echo "Output:   $OUTPUT_DIR"
echo "Source:   $UPSTREAM_DIR"

# Create output directories
mkdir -p "$OUTPUT_DIR/usr/bin"
mkdir -p "$OUTPUT_DIR/usr/lib"
mkdir -p "$OUTPUT_DIR/usr/share/$NAME"

# Load source config if exists
[[ -f "$SRC_DIR/source.conf" ]] && source "$SRC_DIR/source.conf"

# ─────────────────────────────────────────────────────────────────
# BUILD YOUR APP HERE
# ─────────────────────────────────────────────────────────────────

if [[ -d "$UPSTREAM_DIR" ]]; then
    cd "$UPSTREAM_DIR"

    # Example: Build with make
    # make
    # make install DESTDIR="$OUTPUT_DIR" PREFIX=/usr

    # Example: Build with cmake
    # mkdir -p build && cd build
    # cmake .. -DCMAKE_INSTALL_PREFIX=/usr
    # make
    # make install DESTDIR="$OUTPUT_DIR"

    # Example: Build with meson
    # meson setup build --prefix=/usr
    # meson compile -C build
    # meson install -C build --destdir="$OUTPUT_DIR"

    # Example: Copy pre-built binary
    # cp ./target/release/myapp "$OUTPUT_DIR/usr/bin/"

    echo "TODO: Add build commands for $NAME"
else
    echo "No upstream source found. Run 'powos source get $NAME' first."
    echo "Or add build commands that don't require upstream source."
fi

echo "✅ Built: $NAME"
EOF

            chmod +x "$src_dir/build.sh"

            # Create README
            cat > "$src_dir/README.md" << EOF
# $name Source Overlay

Custom build of $name for PowOS.

## Quick Start

\`\`\`bash
# Fetch upstream source
powos source get $name

# Apply patches (if any)
powos source patch $name

# Build the overlay
powos source build $name

# Enable it (overrides system version)
powos source enable $name
\`\`\`

## Adding Patches

Put \`.patch\` files in the \`patches/\` directory.
They'll be applied in alphabetical order.

\`\`\`bash
# Create a patch from your changes
cd upstream
git diff > ../patches/01-my-feature.patch
\`\`\`

## Files

- \`source.conf\` - Source configuration
- \`build.sh\` - Build script
- \`patches/\` - Patches to apply
- \`upstream/\` - Fetched source code (git-ignored)
EOF

            echo ""
            echo -e "${GREEN}✓ Source template created${NC}"
            echo "  Location: $src_dir"
            echo ""
            echo "Next steps:"
            echo "  1. Edit $src_dir/source.conf (set UPSTREAM_URL)"
            echo "  2. Edit $src_dir/build.sh (add build commands)"
            echo "  3. powos source get $name"
            echo "  4. powos source build $name"
            echo "  5. powos source enable $name"
            ;;

        *)
            echo "Usage: powos source <command>"
            echo ""
            echo "Manage source overlays - build custom versions of apps."
            echo ""
            echo "Commands:"
            echo "  list                  List available sources"
            echo "  new <name> [url]      Create new source template"
            echo "  get <name>            Fetch upstream source code"
            echo "  patch <name>          Apply patches to source"
            echo "  build <name>          Build overlay from source"
            echo "  enable <name>         Enable overlay (overrides system)"
            echo "  disable <name>        Disable overlay (restore system)"
            echo ""
            echo "Examples:"
            echo "  powos source new myapp https://github.com/user/myapp"
            echo "  powos source get myapp"
            echo "  powos source build myapp"
            echo "  powos source enable myapp"
            echo ""
            echo "How it works:"
            echo "  1. Source code lives in sources/<name>/"
            echo "  2. Patches in sources/<name>/patches/ are applied"
            echo "  3. build.sh compiles and installs to extensions/<name>/"
            echo "  4. systemd-sysext merges extension over system files"
            echo "  5. Your custom build overrides the system version!"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Container Commands (Podman/Distrobox)
# ═══════════════════════════════════════════════════════════════════

cmd_containers() {
    local action="${1:-list}"
    local DISTROBOX_CONFIG="/etc/powos/containers/distrobox.ini"

    case "$action" in
        list|ls)
            echo -e "${BOLD}${CYAN}Containers${NC}"
            echo "════════════════════════════════════════"
            echo ""

            # Show Distrobox containers
            echo -e "${CYAN}Distrobox Containers:${NC}"
            if command -v distrobox &>/dev/null; then
                distrobox list 2>/dev/null || echo "  (none created yet)"
            else
                echo "  distrobox not installed"
            fi
            echo ""

            # Show Podman containers
            echo -e "${CYAN}Podman Containers:${NC}"
            if command -v podman &>/dev/null; then
                podman ps -a --format "table {{.Names}}\t{{.Status}}\t{{.Image}}" 2>/dev/null || echo "  (none)"
            else
                echo "  podman not installed"
            fi
            echo ""

            # Show images
            echo -e "${CYAN}Images:${NC}"
            if command -v podman &>/dev/null; then
                podman images --format "table {{.Repository}}\t{{.Tag}}\t{{.Size}}" 2>/dev/null | head -10
                local count
                count=$(podman images -q 2>/dev/null | wc -l)
                if [[ "$count" -gt 10 ]]; then
                    echo "  ... and $((count - 10)) more"
                fi
            fi
            ;;

        create)
            local name="${2:-}"
            local image="${3:-}"

            if [[ -z "$name" ]]; then
                echo "Usage: powos containers create <name> [image]"
                echo ""
                echo "Examples:"
                echo "  powos containers create dev              # Default Fedora container"
                echo "  powos containers create arch archlinux   # Arch Linux container"
                echo "  powos containers create ubuntu ubuntu:22.04"
                echo ""
                echo "Predefined containers (from distrobox.ini):"
                echo "  powos containers assemble                # Create all predefined"
                return 1
            fi

            image="${image:-fedora:latest}"
            echo "Creating distrobox container: $name (image: $image)"
            distrobox create --name "$name" --image "$image" --yes
            echo ""
            echo -e "${GREEN}✓ Container '$name' created${NC}"
            echo "  Enter with: powos containers enter $name"
            ;;

        enter)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos containers enter <name>"
                echo ""
                echo "Available containers:"
                distrobox list 2>/dev/null || echo "  (none)"
                return 1
            fi
            distrobox enter "$name"
            ;;

        remove|rm)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos containers remove <name>"
                return 1
            fi
            echo "Removing container: $name"
            distrobox rm "$name" --yes
            echo -e "${GREEN}✓ Container '$name' removed${NC}"
            ;;

        stop)
            local name="${2:-}"
            if [[ -z "$name" ]]; then
                echo "Usage: powos containers stop <name>"
                return 1
            fi
            distrobox stop "$name" --yes
            echo -e "${GREEN}✓ Container '$name' stopped${NC}"
            ;;

        assemble)
            echo -e "${BOLD}${CYAN}Creating Predefined Containers${NC}"
            echo "════════════════════════════════════════"
            echo ""

            local config_file=""
            # Find distrobox.ini
            for path in "$DISTROBOX_CONFIG" "/var/lib/powos/containers/distrobox.ini" "containers/distrobox.ini"; do
                if [[ -f "$path" ]]; then
                    config_file="$path"
                    break
                fi
            done

            if [[ -z "$config_file" ]]; then
                echo -e "${YELLOW}No distrobox.ini found${NC}"
                echo "Create one at: containers/distrobox.ini"
                return 1
            fi

            echo "Using config: $config_file"
            echo ""
            distrobox assemble create --file "$config_file"
            echo ""
            echo -e "${GREEN}✓ Predefined containers created${NC}"
            ;;

        export)
            local name="${2:-}"
            local app="${3:-}"
            if [[ -z "$name" ]] || [[ -z "$app" ]]; then
                echo "Usage: powos containers export <container> <app>"
                echo ""
                echo "Export an app from a container to the host menu"
                echo "Example: powos containers export arch-dev code"
                return 1
            fi
            distrobox-export --app "$app" --container "$name"
            echo -e "${GREEN}✓ Exported '$app' from '$name'${NC}"
            ;;

        podman)
            # Pass through to podman
            shift
            podman "$@"
            ;;

        prune)
            echo "Cleaning up unused container resources..."
            podman system prune -f
            echo -e "${GREEN}✓ Cleanup complete${NC}"
            ;;

        *)
            echo "Usage: powos containers <command>"
            echo ""
            echo "Commands:"
            echo "  list                    List all containers and images"
            echo "  create <name> [image]   Create a new distrobox container"
            echo "  enter <name>            Enter a distrobox container"
            echo "  stop <name>             Stop a container"
            echo "  remove <name>           Remove a container"
            echo "  assemble                Create all predefined containers"
            echo "  export <name> <app>     Export app from container to host"
            echo "  prune                   Clean up unused resources"
            echo "  podman <args>           Pass through to podman"
            echo ""
            echo "Examples:"
            echo "  powos containers create dev"
            echo "  powos containers enter dev"
            echo "  powos containers assemble"
            ;;
    esac
}

# ═══════════════════════════════════════════════════════════════════
# Main Dispatch
# ═══════════════════════════════════════════════════════════════════

case "${1:-}" in
    status)
        cmd_status
        ;;
    sync)
        shift
        cmd_sync "$@"
        ;;
    backup)
        shift
        cmd_backup "$@"
        ;;
    flush)
        cmd_flush
        ;;
    safe)
        cmd_safe
        ;;
    layers)
        shift
        cmd_layers "$@"
        ;;
    rollback)
        shift
        cmd_rollback "$@"
        ;;
    update)
        shift
        cmd_update "$@"
        ;;
    upgrade)
        shift
        source "$POWOS_LIB/upgrade.sh"
        cmd_upgrade "$@"
        ;;
    reload|apply)
        shift
        source "$POWOS_LIB/reload.sh"
        cmd_reload "$@"
        ;;
    self)
        shift
        # The edit → test → push dev loop (safe pull, transient live apply).
        source "$POWOS_LIB/self.sh"
        cmd_self "$@"
        ;;
    menu)
        shift
        # Guided, categorized TTY menu → dispatches to real commands.
        source "$POWOS_LIB/menu.sh"
        cmd_menu "$@"
        ;;
    health)
        shift
        cmd_health "$@"
        ;;
    mobile)
        shift
        experimental_warn mobile
        source "$POWOS_LIB/mobile.sh"
        cmd_mobile "$@"
        ;;
    hardware)
        cmd_hardware
        ;;
    profile)
        cmd_hardware | grep ACTIVE_PROFILE
        ;;
    containers|container|c)
        shift
        cmd_containers "$@"
        ;;
    install|i)
        shift
        # Route through the containment-first installer (probes flatpak/rpm/brew,
        # defaults to the most contained backend). It calls back into cmd_install
        # for the legacy container (-c) and host (--host) paths.
        source "$POWOS_LIB/install-router.sh"
        cmd_install_route "$@"
        ;;
    remove|uninstall)
        shift
        # Mirror of the install router: probes every backend (flatpak, sandbox,
        # brew, host layer), removes from each place the thing is found.
        source "$POWOS_LIB/uninstall.sh"
        cmd_remove "$@"
        ;;
    config)
        shift
        # One front door for system toggles (ssh, cachefs, ...): show state,
        # flip on/off, apply immediately. --json for GUIs.
        source "$POWOS_LIB/config.sh"
        cmd_config "$@"
        ;;
    install-system|install-disk)
        shift
        source "$POWOS_LIB/install-system.sh"
        cmd_install_system "$@"
        ;;
    vm)
        shift
        experimental_warn vm
        source "$POWOS_LIB/vm.sh"
        cmd_vm "$@"
        ;;
    base)
        shift
        source "$POWOS_LIB/base.sh"
        cmd_base "$@"
        ;;
    boot)
        shift
        source "$POWOS_LIB/boot-manager.sh"
        cmd_boot "$@"
        ;;
    games)
        shift
        source "$POWOS_LIB/games.sh"
        cmd_games "$@"
        ;;
    ramboot)
        shift
        experimental_warn ramboot
        source "$POWOS_LIB/ramboot.sh"
        cmd_ramboot "$@"
        ;;
    doctor)
        shift
        source "$POWOS_LIB/doctor.sh"
        cmd_doctor "$@"
        ;;
    install-wizard|install)
        shift
        source "$POWOS_LIB/install-wizard.sh"
        cmd_install_wizard "$@"
        ;;
    windows|win)
        shift
        experimental_warn windows
        source "$POWOS_LIB/windows.sh"
        cmd_windows "$@"
        ;;
    cuda)
        shift
        source "$POWOS_LIB/cuda.sh"
        cmd_cuda "$@"
        ;;
    driver)
        shift
        source "$POWOS_LIB/driver.sh"
        cmd_driver "$@"
        ;;
    registry)
        shift
        source "$POWOS_LIB/registry.sh"
        cmd_registry "$@"
        ;;
    gpu)
        shift
        experimental_warn gpu
        source "$POWOS_LIB/gpu.sh"
        cmd_gpu "$@"
        ;;
    overview|ov)
        shift
        source "$POWOS_LIB/overview.sh"
        cmd_overview "$@"
        ;;
    services|svc)
        shift
        source "$POWOS_LIB/services.sh"
        cmd_services "$@"
        ;;
    build|b)
        shift
        cmd_build "$@"
        ;;
    dev|d)
        shift
        cmd_dev "$@"
        ;;
    ai)
        shift
        case "${1:-}" in
            agents|list)
                ai_list_agents
                ;;
            clients)
                ai_list_clients
                ;;
            sessions)
                ai_sessions
                ;;
            session)
                shift
                case "${1:-list}" in
                    list)
                        ai_sessions
                        ;;
                    new|create)
                        shift
                        ai_new_session "$@"
                        ;;
                    delete|rm)
                        shift
                        ai_delete_session "${1:-}"
                        ;;
                    export)
                        shift
                        ai_export_session "$@"
                        ;;
                    clear)
                        if declare -f ai_session_clear_all &>/dev/null; then
                            ai_session_clear_all
                        fi
                        ;;
                    *)
                        echo -e "${RED}Unknown session command: $1${NC}" >&2
                        echo "Usage: powos ai session {list|new|delete|export|clear}" >&2
                        exit 1
                        ;;
                esac
                ;;
            help|--help|-h)
                ai_help
                ;;
            "")
                ai_help
                ;;
            *)
                ai_call "$@"
                ;;
        esac
        ;;
    source|src|s)
        # Deprecated - redirect to dev
        echo -e "${YELLOW}Note: 'powos source' is deprecated. Use 'powos dev' instead.${NC}"
        shift
        cmd_dev "$@"
        ;;
    remote)
        # Legacy alias for backup
        echo -e "${YELLOW}Note: 'powos remote' is now 'powos backup'${NC}"
        shift
        cmd_backup "$@"
        ;;
    state)
        # Legacy alias for backup
        echo -e "${YELLOW}Note: 'powos state' is now 'powos backup'${NC}"
        shift
        cmd_backup "$@"
        ;;
    version|--version|-v)
        cmd_version
        ;;
    help|--help|-h|"")
        usage
        ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'powos help' for usage"
        exit 1
        ;;
esac
