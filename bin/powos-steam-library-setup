#!/usr/bin/env bash
# powos-steam-library-setup — register ~/Games as a Steam library on first login.
#
# Why: Bazzite's ostree layout mounts /etc as a separate btrfs subvolume,
# which shows up in /proc/mounts with the full disk's free space (7.3 TB).
# Steam's install dialog reads /proc/mounts to build its "install location"
# dropdown and offers /etc as a target — technically the mount has space,
# but /etc is root-owned config territory, not a games directory.
#
# Fix: create ~/Games/steamapps/ with the standard Steam library layout
# and register it in Steam's libraryfolders.vdf. Once Steam sees a REAL
# user-writable library, its install dialog defaults to that instead of /etc.
#
# Correct file target: ~/.local/share/Steam/steamapps/libraryfolders.vdf is
# the PRIMARY config Steam reads on startup. ~/.local/share/Steam/config/
# libraryfolders.vdf is a legacy duplicate Steam writes to for older tools
# but does NOT read from — writing there alone gets overwritten on next
# Steam launch (v1 of this script had that bug). We write to BOTH so tools
# that check either path stay consistent.
#
# STRICTLY ADDITIVE (per the additive-only rule for user-facing state):
#   • never rewrites an existing libraryfolders.vdf entry
#   • never reorders existing libraries
#   • only touches Steam config if Steam isn't currently running
#   • marker-gated so it only runs once per user (v3 marker — v1 and v2
#     targeted the wrong file)

set -uo pipefail

marker="${XDG_STATE_HOME:-$HOME/.local/state}/powos/steam-library-configured-v3"
[[ -f "$marker" ]] && exit 0

GAMES_DIR="$HOME/Games"
STEAM_ROOT="$HOME/.local/share/Steam"
STEAM_LIB_PRIMARY="$STEAM_ROOT/steamapps/libraryfolders.vdf"
STEAM_LIB_LEGACY="$STEAM_ROOT/config/libraryfolders.vdf"

# 1. Create the games directory + standard Steam subdirs. Idempotent.
mkdir -p "$GAMES_DIR/steamapps/common" \
         "$GAMES_DIR/steamapps/downloading" \
         "$GAMES_DIR/steamapps/workshop"

# 2. Drop a libraryfolder.vdf marker — this is the file Steam looks for to
#    confirm "yes, this directory really is a Steam library" (as opposed to
#    a random folder that happens to have `steamapps` in it).
if [[ ! -f "$GAMES_DIR/steamapps/libraryfolder.vdf" ]]; then
    cat > "$GAMES_DIR/steamapps/libraryfolder.vdf" <<'EOF'
"libraryfolder"
{
	"contentstatsid"		"1"
}
EOF
fi

# 3. If Steam has never run, we can't do the vdf edit yet — Steam creates
#    those files on first launch. Bail cleanly; next login retries.
if [[ ! -f "$STEAM_LIB_PRIMARY" ]]; then
    exit 0
fi

# 4. Never edit a running Steam's config — the client re-saves the file
#    from memory and clobbers our change. Defer to a future session.
if pgrep -x steam >/dev/null 2>&1; then
    exit 0
fi

# 5. Check if ~/Games is already registered in the primary file.
if grep -qF "\"$GAMES_DIR\"" "$STEAM_LIB_PRIMARY"; then
    mkdir -p "$(dirname "$marker")"
    touch "$marker"
    exit 0
fi

# 6. Delegate the edit to Python — VDF is ugly to parse in awk/sed and the
#    exact tab layout matters for Steam's parser. The Python is inline and
#    only ~30 lines; keeping it here avoids shipping a second helper file.
python3 - "$STEAM_LIB_PRIMARY" "$STEAM_LIB_LEGACY" "$GAMES_DIR" <<'PY'
import os, random, re, sys
GAMES = sys.argv[3]
for path in sys.argv[1:3]:
    if not os.path.exists(path):
        continue
    with open(path) as f:
        content = f.read()
    if GAMES in content:
        continue
    max_idx = -1
    for m in re.finditer(r'^\t"(\d+)"$', content, re.MULTILINE):
        max_idx = max(max_idx, int(m.group(1)))
    next_idx = max_idx + 1
    # int64 max — Steam parses contentid as SIGNED 64-bit. If we hand it
    # a value above 2^63-1 the parse wraps to negative and Steam
    # re-processes the entry on next write, blanking the "label" field
    # as a side effect (visible symptom: dropdown shows /etc for our
    # entry instead of "Games").
    contentid = str(random.randint(10**18, (1 << 63) - 1))
    block = (
        f'\t"{next_idx}"\n'
        '\t{\n'
        f'\t\t"path"\t\t"{GAMES}"\n'
        # Explicit label. Steam falls back to the mount-point name when
        # this is empty, and on Bazzite's ostree layout that falls back
        # to "/etc" (btrfs subvols sharing the root device, sorted
        # alphabetically). Forcing "Games" makes the dropdown readable.
        '\t\t"label"\t\t"Games"\n'
        f'\t\t"contentid"\t\t"{contentid}"\n'
        '\t\t"totalsize"\t\t"0"\n'
        '\t\t"update_clean_bytes_tally"\t\t"0"\n'
        '\t\t"time_last_update_verified"\t\t"0"\n'
        '\t\t"apps"\n'
        '\t\t{\n'
        '\t\t}\n'
        '\t}\n'
    )
    # Only replace the file's OWN closing brace, not any nested ones.
    new_content = re.sub(r'^\}\s*$', block + '}', content, count=1, flags=re.MULTILINE)
    # Refuse to write if regex didn't find the top-level close (means the
    # file structure isn't what we expect — safer to bail than corrupt it).
    if new_content == content:
        continue
    with open(path, 'w') as f:
        f.write(new_content)
PY

mkdir -p "$(dirname "$marker")"
touch "$marker"
