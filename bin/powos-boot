#!/bin/bash
# PowOS Boot Entrypoint
# Orchestrates the boot sequence: Init -> Hardware Detect -> Overlays -> Desktop

set -e

GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
YELLOW=$'\033[0;33m'
MAGENTA=$'\033[0;35m'
NC=$'\033[0m'

log() { echo -e "${CYAN}[powos]${NC} $*"; }
log_ok() { echo -e "${GREEN}[  OK  ]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }

clear
echo -e "${MAGENTA}"
cat << 'EOF'
    ____                 ____  _____
   / __ \____ _      __/ __ \/ ___/
  / /_/ / __ \ | /| / / / / /\__ \
 / ____/ /_/ / |/ |/ / /_/ /___/ /
/_/    \____/|__/|__/\____//____/

     Portable Gaming Workstation
EOF
echo -e "${NC}"

# ═══════════════════════════════════════════════════════════════════
# 1. Hardware Detection
# ═══════════════════════════════════════════════════════════════════
log "Running Chameleon Boot (Hardware Detection)..."

# Run the specialized detection script
if [[ -x /usr/lib/powos/powos-hardware-detect ]]; then
    /usr/lib/powos/powos-hardware-detect
else
    # Fallback to local script if not installed in system path
    bash lib/hardware-detect.sh detect
fi

# Display result
if [[ -f /run/powos/hardware ]]; then
    source /run/powos/hardware
    log_ok "Hardware: $GPU_TYPE / $FORM_FACTOR / $POWER_SOURCE"
else
    log_warn "Hardware detection did not produce state file"
fi

# ═══════════════════════════════════════════════════════════════════
# 2. Overlay Loading (System Extensions)
# ═══════════════════════════════════════════════════════════════════
log "Loading System Overlays..."

# Run the specialized overlay loader
if [[ -x /usr/lib/powos/powos-overlay-load ]]; then
    /usr/lib/powos/powos-overlay-load
else
    log_warn "Overlay loader not found"
fi

# ═══════════════════════════════════════════════════════════════════
# 3. Legacy Overlay Support (for overlays/ directory)
# ═══════════════════════════════════════════════════════════════════
# This handles the older "cp" style overlays if they exist and haven't been migrated
if [[ -d "/usr/lib/powos/overlays" ]]; then
    log "Checking for legacy overlays..."
    # (Optional: Add logic here if strictly needed, but prefer sysext above)
fi

# ═══════════════════════════════════════════════════════════════════
# 4. RAM Overlay (Unplug Resilience) + Layer Sync
# ═══════════════════════════════════════════════════════════════════
log "Checking RAM Overlay status..."

RAMBOOT_STATE="/run/powos/ramboot-state"
LAYER_SYNC="/usr/lib/powos/ramfs/layer-sync.py"

# Check if we booted with full RAM boot (dracut module set this up)
if [[ -f "$RAMBOOT_STATE" ]]; then
    source "$RAMBOOT_STATE"
    log_ok "Full RAM boot active (set up by initramfs)"
    log "  Entire OS running from RAM - USB can be unplugged anytime"
    log "  RAM allocated: ${POWOS_RAM_SIZE:-unknown}"
    log "  Active layers: ${POWOS_LAYERS_ACTIVE:-base}"

    # Show layer status
    if [[ "$POWOS_SKIP_CUSTOM" == "1" ]]; then
        log_warn "  ROLLBACK: Custom layer skipped"
    fi
    if [[ "$POWOS_SKIP_UPDATES" == "1" ]]; then
        log_warn "  ROLLBACK: Updates layer skipped"
    fi

    # Start layer sync daemon (syncs RAM changes to custom layer on USB)
    # Skip if systemd service is already managing it (avoid duplicate daemons)
    if systemctl is-active --quiet powos-layer-sync.service 2>/dev/null; then
        log "  Layer sync active via systemd (powos-layer-sync.service)"
    elif [[ -x "$LAYER_SYNC" ]] && [[ -f /run/powos/layer-paths ]]; then
        log "  Starting layer sync daemon..."
        python3 "$LAYER_SYNC" --interval 60 &
        LAYER_SYNC_PID=$!
        log "  Layer sync daemon started (PID: $LAYER_SYNC_PID)"
        log "  RAM changes will sync to custom layer every 60s"
    fi

    # Run userspace init for additional setup
    if [[ -x /usr/lib/powos/overlay-init.sh ]]; then
        /usr/lib/powos/overlay-init.sh 2>&1 | while read -r line; do log "    $line"; done
    fi

    OVERLAY_ENABLED="ramboot"
fi

# ═══════════════════════════════════════════════════════════════════
# 5. CacheFS for User Data (Lazy-Loading)
# ═══════════════════════════════════════════════════════════════════
log "Setting up user data filesystem..."

# Load system configuration (sets POWOS_CACHEFS_ENABLED, POWOS_CACHE_SIZE, etc.)
if [[ -f /etc/powos/config ]]; then
    # shellcheck source=/dev/null
    source /etc/powos/config
fi

CACHEFS_SCRIPT="/usr/lib/powos/cachefs/powos-cachefs.py"
CACHEFS_SYNC="/usr/lib/powos/cachefs/cachefs-sync.py"
USB_HOME_PATH="/mnt/powos-usb/home"
CACHE_DIR="/run/powos/cachefs"
CACHE_SIZE="${POWOS_CACHE_SIZE:-4G}"

# Detect USB
USB_DETECTED="false"
if blkid | grep -qE "POWOS-(DATA|HOME)"; then
    USB_DETECTED="true"
    USB_DEV=$(blkid -L "POWOS-DATA" 2>/dev/null || blkid -L "POWOS-HOME" 2>/dev/null)
    log "  Detected USB: $USB_DEV"

    # Mount USB if not already mounted
    if ! mountpoint -q /mnt/powos-usb 2>/dev/null; then
        mkdir -p /mnt/powos-usb
        mount "$USB_DEV" /mnt/powos-usb 2>/dev/null && log "  Mounted USB at /mnt/powos-usb"
    fi
fi

if [[ "$USB_DETECTED" == "true" ]] && [[ -x "$CACHEFS_SCRIPT" ]] && [[ "${POWOS_CACHEFS_ENABLED:-false}" == "true" ]]; then
    log "  Starting CacheFS (lazy-loading with ${CACHE_SIZE} RAM cache)..."

    # Create cache directory
    mkdir -p "$CACHE_DIR" /home/powos

    # Ensure USB home directory exists
    mkdir -p "$USB_HOME_PATH"

    # Start CacheFS in background
    python3 "$CACHEFS_SCRIPT" \
        "$USB_HOME_PATH" \
        /home/powos \
        --cache-dir "$CACHE_DIR" \
        --cache-size "$CACHE_SIZE" \
        --foreground &
    CACHEFS_PID=$!

    sleep 2  # Give it time to mount

    if mountpoint -q /home/powos 2>/dev/null; then
        log_ok "CacheFS mounted at /home/powos"
        log "  Metadata: always in RAM"
        log "  Files: lazy-loaded on access, cached in RAM"
        log "  USB can be unplugged - cached files remain accessible"

        # Start sync daemon
        if [[ -x "$CACHEFS_SYNC" ]]; then
            python3 "$CACHEFS_SYNC" \
                --cache-dir "$CACHE_DIR" \
                --backing-path "$USB_HOME_PATH" &
            log "  CacheFS sync daemon started"
        fi

        CACHEFS_ENABLED="true"
    else
        log_warn "CacheFS failed to mount, using direct mode"
        kill $CACHEFS_PID 2>/dev/null || true
        mkdir -p /home/powos
        CACHEFS_ENABLED="false"
    fi
else
    # No USB or no CacheFS - use direct mode
    if [[ "$USB_DETECTED" == "true" ]]; then
        log "  CacheFS not available, using direct USB access"
        # Bind mount USB home directly
        if [[ -d "$USB_HOME_PATH" ]]; then
            mkdir -p /home/powos
            mount --bind "$USB_HOME_PATH" /home/powos 2>/dev/null || true
        fi
    else
        log "  No USB detected, using tmpfs for home"
        mkdir -p /home/powos
        mount -t tmpfs -o size=2G tmpfs /home/powos 2>/dev/null || true
    fi
    CACHEFS_ENABLED="false"
fi

# Ensure home exists and has correct permissions
mkdir -p /home/powos
chown -R 1000:1000 /home/powos 2>/dev/null || true

# ═══════════════════════════════════════════════════════════════════
# 5. KDE Plasma + KasmVNC
# ═══════════════════════════════════════════════════════════════════
log "Starting Desktop Environment..."

# User setup
if ! id powos &>/dev/null; then
    useradd -m -G wheel -u 1000 powos
    echo "powos:powos" | chpasswd
fi
echo "powos ALL=(ALL) NOPASSWD:ALL" > /etc/sudoers.d/powos

# D-Bus
mkdir -p /run/dbus /var/lib/dbus
dbus-uuidgen > /var/lib/dbus/machine-id 2>/dev/null || true
dbus-daemon --system --fork 2>/dev/null || true

# Install TigerVNC, noVNC, and X11 KDE support
log "  Installing VNC and KDE X11 support..."
dnf install -y tigervnc-server novnc python3-websockify plasma-workspace-x11 2>&1 | tail -5

# VNC config
mkdir -p /home/powos/.vnc

# Create xstartup for KDE Plasma X11
cat > /home/powos/.vnc/xstartup << 'EOF'
#!/bin/bash
# Force software rendering to avoid NVIDIA driver conflicts
export __EGL_VENDOR_LIBRARY_FILENAMES=/dev/null
export LIBGL_ALWAYS_SOFTWARE=1
export XDG_SESSION_TYPE=x11
export XDG_RUNTIME_DIR=/tmp/runtime-powos
mkdir -p "$XDG_RUNTIME_DIR"
chmod 700 "$XDG_RUNTIME_DIR"
exec dbus-launch --exit-with-session startplasma-x11
EOF
chmod +x /home/powos/.vnc/xstartup

# Create VNC password (password: powos)
echo "powos" | vncpasswd -f > /home/powos/.vnc/passwd
chmod 600 /home/powos/.vnc/passwd
chown -R powos:powos /home/powos/.vnc

# Kill any existing VNC
vncserver -kill :1 2>/dev/null || true

# Start TigerVNC (force software rendering to avoid NVIDIA EGL crash)
log "  Starting KDE Plasma via TigerVNC..."
su - powos -c "__EGL_VENDOR_LIBRARY_FILENAMES=/dev/null LIBGL_ALWAYS_SOFTWARE=1 vncserver :1 -geometry 1920x1080 -depth 24 -localhost no" 2>&1 || log_warn "VNC start issue"

# Start noVNC (websocket proxy for browser access)
log "  Starting noVNC web proxy..."
/usr/bin/websockify --web=/usr/share/novnc 8443 localhost:5901 &

echo ""
echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}  PowOS Ready!${NC}"
echo -e "${GREEN}════════════════════════════════════════════════════════════${NC}"
echo ""
echo "  noVNC Access:  http://localhost:6091/vnc.html"
echo "  VNC Direct:    localhost:5901"
echo "  Password:      powos"
echo ""

# Layer status
if [[ "$OVERLAY_ENABLED" == "ramboot" ]]; then
    echo -e "  ${GREEN}Layers:${NC}        ${POWOS_LAYERS_ACTIVE:-base}"
    echo -e "  ${GREEN}OS:${NC}            Running from RAM (full ramboot)"
    if [[ -n "$LAYER_SYNC_PID" ]]; then
        echo "                 Changes sync to custom layer every 60s"
    fi
else
    echo -e "  ${YELLOW}OS:${NC}            Standard boot (no ramboot)"
fi

# User data status
if [[ "$CACHEFS_ENABLED" == "true" ]]; then
    echo -e "  ${GREEN}User Data:${NC}     CacheFS (lazy-load + ${CACHE_SIZE} cache)"
    echo "                 Files load on access, stay in RAM"
elif [[ "$USB_DETECTED" == "true" ]]; then
    echo -e "  ${CYAN}User Data:${NC}     Direct USB (no lazy-load)"
else
    echo -e "  ${YELLOW}User Data:${NC}     tmpfs (no USB detected)"
fi

# Protection status
echo ""
if [[ "$OVERLAY_ENABLED" == "ramboot" ]] && [[ "$CACHEFS_ENABLED" == "true" ]]; then
    echo -e "  ${GREEN}✓ FULLY PROTECTED${NC} - USB can be unplugged anytime!"
elif [[ "$OVERLAY_ENABLED" == "ramboot" ]]; then
    echo -e "  ${GREEN}✓ OS Protected${NC} - OS in RAM, user data may need USB"
else
    echo -e "  ${YELLOW}○ Standard Mode${NC} - USB required"
fi

echo ""
echo "  Commands:"
echo "    powos status     - Full system status"
echo "    powos layers     - View layer stack"
echo "    powos sync       - Force sync to USB"
echo "    powos rollback   - Rollback options"
echo ""

exec tail -f /dev/null
