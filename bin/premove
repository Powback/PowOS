#!/usr/bin/env bash
# premove - Remove packages and automatically update infrastructure code
#
# Usage: premove <package> [package...]
#
# This script:
# 1. Removes packages immediately (runtime)
# 2. Updates distrobox.ini (config)
# 3. Commits the change to git (persistence)

set -euo pipefail

# ─────────────────────────────────────────────────────────────────
# Configuration
# ─────────────────────────────────────────────────────────────────

POWOS_ROOT="${POWOS_ROOT:-$HOME/powos}"
DISTROBOX_INI="${POWOS_ROOT}/containers/distrobox.ini"
LOG_PREFIX="[premove]"

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    NC='\033[0m'
else
    RED='' GREEN='' YELLOW='' BLUE='' NC=''
fi

# ─────────────────────────────────────────────────────────────────
# Helper Functions
# ─────────────────────────────────────────────────────────────────

log_info() {
    echo -e "${BLUE}${LOG_PREFIX}${NC} $*"
}

log_success() {
    echo -e "${GREEN}${LOG_PREFIX}${NC} $*"
}

log_warn() {
    echo -e "${YELLOW}${LOG_PREFIX}${NC} $*"
}

log_error() {
    echo -e "${RED}${LOG_PREFIX}${NC} $*" >&2
}

# Detect which package manager is available
detect_package_manager() {
    if command -v pacman &>/dev/null; then
        echo "pacman"
    elif command -v dnf &>/dev/null; then
        echo "dnf"
    elif command -v apt-get &>/dev/null; then
        echo "apt"
    elif command -v apk &>/dev/null; then
        echo "apk"
    elif command -v zypper &>/dev/null; then
        echo "zypper"
    else
        echo "unknown"
    fi
}

# Remove packages using the detected package manager
remove_packages() {
    local pm="$1"
    shift
    local packages=("$@")

    log_info "Removing with ${pm}: ${packages[*]}"

    case "$pm" in
        pacman)
            sudo pacman -Rs --noconfirm "${packages[@]}" 2>/dev/null || \
            sudo pacman -R --noconfirm "${packages[@]}"
            ;;
        dnf)
            sudo dnf remove -y "${packages[@]}"
            ;;
        apt)
            sudo apt-get remove -y "${packages[@]}"
            sudo apt-get autoremove -y
            ;;
        apk)
            sudo apk del "${packages[@]}"
            ;;
        zypper)
            sudo zypper remove -y "${packages[@]}"
            ;;
        *)
            log_error "Unknown package manager: $pm"
            return 1
            ;;
    esac
}

# Remove package from distrobox.ini
unrecord_package() {
    local pkg="$1"
    local ini_file="$DISTROBOX_INI"

    if [[ ! -f "$ini_file" ]]; then
        log_warn "Config file not found: $ini_file"
        return 0
    fi

    # Check if package is in config
    if ! grep -q "additional_packages=.*\b${pkg}\b" "$ini_file" 2>/dev/null; then
        log_warn "Package '$pkg' not found in config"
        return 0
    fi

    # Remove the package from additional_packages line
    # Handle: "pkg1 pkg2 pkg3" -> remove pkg2 -> "pkg1 pkg3"
    sed -i "s/\badditional_packages=\(.*\) ${pkg}\b/additional_packages=\1/" "$ini_file"
    sed -i "s/\badditional_packages=${pkg} \(.*\)/additional_packages=\1/" "$ini_file"
    sed -i "s/\badditional_packages=${pkg}$/additional_packages=/" "$ini_file"

    # Clean up any double spaces
    sed -i 's/additional_packages=  */additional_packages=/g' "$ini_file"

    log_info "Removed '$pkg' from config"
}

# Commit changes to git
commit_changes() {
    local packages=("$@")
    local msg="remove: ${packages[*]}"

    cd "$POWOS_ROOT"

    # Check if we're in a git repo
    if ! git rev-parse --git-dir &>/dev/null; then
        log_warn "Not a git repository, skipping commit"
        return 0
    fi

    # Check if there are changes
    if ! git diff --quiet "$DISTROBOX_INI" 2>/dev/null; then
        git add "$DISTROBOX_INI"
        git commit -m "$msg" || log_warn "Nothing to commit"
        log_success "Committed: $msg"
    else
        log_warn "No changes to commit"
    fi
}

# ─────────────────────────────────────────────────────────────────
# Main
# ─────────────────────────────────────────────────────────────────

main() {
    local packages=("$@")

    # Validate arguments
    if [[ ${#packages[@]} -eq 0 ]]; then
        echo "Usage: premove <package> [package...]"
        echo ""
        echo "Remove packages and update infrastructure code."
        echo ""
        echo "Examples:"
        echo "  premove ripgrep"
        echo "  premove node python"
        echo ""
        echo "Environment variables:"
        echo "  POWOS_ROOT       Root directory (default: \$HOME/powos)"
        echo "  POWOS_SKIP_GIT   Skip git commit if set to 1"
        exit 1
    fi

    log_info "Removing: ${packages[*]}"

    # Step 1: Detect package manager
    local pm
    pm=$(detect_package_manager)

    if [[ "$pm" == "unknown" ]]; then
        log_error "No supported package manager found"
        exit 1
    fi

    # Step 2: Remove packages (runtime)
    if ! remove_packages "$pm" "${packages[@]}"; then
        log_warn "Some packages may not have been removed"
    fi

    # Step 3: Update config
    for pkg in "${packages[@]}"; do
        unrecord_package "$pkg"
    done

    # Step 4: Git commit (persistence)
    if [[ "${POWOS_SKIP_GIT:-0}" != "1" ]]; then
        commit_changes "${packages[@]}"
    fi

    log_success "Removed and updated config: ${packages[*]}"
}

main "$@"
