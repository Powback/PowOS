#!/bin/bash
# powos-game-shim — dormant exec wrapper for Steam game launch options.
#
# Installed into a game's Steam launch options as:
#   powos-game-shim %command%
#
# Behavior:
#   If /run/powos/verify/<appid>.env exists → source it (injects MangoHud,
#     PROTON_LOG, gamescope wrapping, crash-report dir, etc.), then exec.
#   Otherwise → exec %command% untouched. Zero overhead outside verify runs.
#
# The shim also writes its PID + child PID to /run/powos/verify/<appid>.pid
# so the harness can find the game process without /proc scanning.
#
# This shim is generic: the env-file sourcing pattern lets any PowOS subsystem
# (verify, rework/overlayfs, streaming) inject per-launch env by writing the
# sentinel file. Name it powos-game-shim, not powos-verify-shim, for reuse.

set -uo pipefail

# Resolve the appid from Steam's env (set by the client before launch)
APPID="${SteamAppId:-${STEAM_APPID:-unknown}}"
SENTINEL="/run/powos/verify/${APPID}.env"
PID_FILE="/run/powos/verify/${APPID}.pid"

# ── Phase 1: Overlay mount-ensure ──────────────────────────────────────
# If a mod manifest exists for this game, ensure the overlay is mounted.
# The manifest → game mapping is resolved by scanning manifests for appid.
MODS_STATE_DIR="${MODS_STATE_DIR:-${XDG_STATE_HOME:-$HOME/.local/state}/powos/mods}"
MODS_MANIFEST_DIR="$MODS_STATE_DIR/manifests"
# Check both mount bases — kernel helper uses /run, fuse uses /tmp
MODS_MOUNT_BASE_KERNEL="/run/powos-mods"
MODS_MOUNT_BASE_FUSE="${MODS_MOUNT_BASE:-/tmp/powos-mods}"

if [[ -d "$MODS_MANIFEST_DIR" ]] && [[ "$APPID" != "unknown" ]]; then
    # Find the manifest for this appid
    _game=""
    for mf in "$MODS_MANIFEST_DIR"/*.json; do
        [[ -f "$mf" ]] || continue
        _mf_appid="$(python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('appid',''))" "$mf" 2>/dev/null)" || continue
        if [[ "$_mf_appid" == "$APPID" ]]; then
            _game="$(basename "$mf" .json)"
            break
        fi
    done

    if [[ -n "$_game" ]]; then
        # Try kernel mount base first, then fuse
        _merged=""
        for _base in "$MODS_MOUNT_BASE_KERNEL" "$MODS_MOUNT_BASE_FUSE"; do
            if mountpoint -q "$_base/$_game/merged" 2>/dev/null; then
                _merged="$_base/$_game/merged"
                break
            fi
        done

        # If not mounted anywhere, try to mount via powos CLI
        if [[ -z "$_merged" ]]; then
            # Try to mount via powos CLI (which sources deploy.sh)
            _powos="${POWOS_BIN:-$(command -v powos 2>/dev/null || echo /usr/bin/powos)}"
            if [[ -x "$_powos" ]]; then
                "$_powos" mods deploy "$_game" >/dev/null 2>&1 || true
            fi
        fi

        # After deploy attempt, re-check both bases for the mounted overlay
        if [[ -z "$_merged" ]]; then
            for _base in "$MODS_MOUNT_BASE_KERNEL" "$MODS_MOUNT_BASE_FUSE"; do
                if mountpoint -q "$_base/$_game/merged" 2>/dev/null; then
                    _merged="$_base/$_game/merged"
                    break
                fi
            done
        fi

        # If overlay is mounted, rewrite STEAM_COMPAT_INSTALL_PATH so
        # Proton sees modded files
        if [[ -n "$_merged" ]] && mountpoint -q "$_merged" 2>/dev/null; then
            export STEAM_COMPAT_INSTALL_PATH="$_merged"
        fi
    fi
    unset _game _merged _powos _mf_appid _base
fi

# ── Phase 2: Source verify env sentinel ────────────────────────────────
if [[ -f "$SENTINEL" ]]; then
    # shellcheck disable=SC1090
    source "$SENTINEL"
fi

# Write our PID and the child PID for the harness
if [[ -d "/run/powos/verify" ]]; then
    echo "shim_pid=$$" > "$PID_FILE"
fi

# ── Phase 3: Exec the game ────────────────────────────────────────────
exec "$@"
