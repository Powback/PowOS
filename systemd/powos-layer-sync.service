[Unit]
Description=PowOS Layer Sync Daemon
Documentation=man:powos(8)
After=powos-ramboot-init.service local-fs.target
Requires=powos-ramboot-init.service
ConditionPathExists=/run/powos/ramboot-state
ConditionPathExists=/run/powos/layer-paths

[Service]
Type=simple
# Interval is configurable via `powos config sync-interval N` →
# POWOS_SYNC_INTERVAL in /etc/powos/config (default below if unset).
Environment=POWOS_SYNC_INTERVAL=60
EnvironmentFile=-/etc/powos/config
ExecStart=/usr/bin/python3 /usr/lib/powos/ramfs/layer-sync.py --interval ${POWOS_SYNC_INTERVAL}
# No ExecReload: the daemon handles only SIGTERM/SIGINT — SIGHUP would kill it
# (Restart=on-failure would then respawn it mid-cycle).
Restart=on-failure
RestartSec=10

# Security hardening
NoNewPrivileges=false
ProtectSystem=false
PrivateTmp=false

# Environment
Environment=PYTHONUNBUFFERED=1

# Graceful shutdown: systemd sends SIGTERM and the daemon performs its own
# final sync before exiting. Deliberately NO ExecStop — spawning a second
# --sync-now process here would race the daemon's shutdown sync on the same
# destination (all syncs also serialize on /run/powos/layer-sync.lock).
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
